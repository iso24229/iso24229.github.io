---
// Modal search interface. Lazy-loads /search-index.json on first open,
// builds a MiniSearch instance, and renders live results. Triggered
// from the Header search button or the Cmd/Ctrl+K keyboard shortcut.
//
// All client behaviour lives in src/scripts/searchClient.ts.
import Icon from './Icon.astro';
---

<button
  type="button"
  id="search-trigger"
  class="p-2 rounded-sm text-ink-muted hover:text-ink hover:bg-paper-raised transition-colors"
  aria-label="Search (Ctrl+K)"
  title="Search (Ctrl+K)"
>
  <Icon name="search" />
</button>

<div
  id="search-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Search the register"
  class="hidden fixed inset-0 z-50"
>
  <div class="absolute inset-0 bg-ink/40 backdrop-blur-sm" data-search-close></div>
  <div class="relative mx-auto mt-[10vh] w-[min(640px,92vw)] bg-paper rounded shadow-2xl border border-rule overflow-hidden">
    <div class="flex items-center gap-3 px-4 py-3 border-b border-rule">
      <Icon name="search" class="text-ink-subtle shrink-0" />
      <input
        id="search-input"
        type="search"
        autocomplete="off"
        spellcheck="false"
        placeholder="Search systems, authorities, languages, scripts, pages…"
        class="flex-1 bg-transparent text-base text-ink placeholder:text-ink-subtle focus:outline-none"
      />
      <button
        type="button"
        data-search-close
        class="text-xs font-mono text-ink-subtle hover:text-ink px-2 py-1 border border-rule rounded"
        aria-label="Close search"
      >Esc</button>
    </div>
    <div id="search-results" class="max-h-[60vh] overflow-y-auto"></div>
    <div class="px-4 py-2 border-t border-rule text-xs text-ink-subtle flex items-center justify-between">
      <span><kbd class="font-mono">↑↓</kbd> navigate · <kbd class="font-mono">↵</kbd> open · <kbd class="font-mono">esc</kbd> close</span>
      <span>Powered by MiniSearch</span>
    </div>
  </div>
</div>

<script>
  import '../scripts/searchClient';
</script>
