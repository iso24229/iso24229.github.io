---
import { navigation } from '../config';

const currentPath = Astro.url.pathname;
const isActive = (href: string): boolean =>
  currentPath === href || currentPath.startsWith(`${href}/`);
---

<nav aria-label="Primary" class="hidden md:flex items-center gap-0.5">
  {
    navigation.map((item) => (
      <a
        href={item.href}
        title={item.description}
        class:list={[
          'px-3 py-2 text-sm font-medium rounded-sm transition-colors',
          isActive(item.href)
            ? 'text-ink bg-paper-raised'
            : 'text-ink-muted hover:text-ink hover:bg-paper-raised/60',
        ]}
      >
        {item.label}
      </a>
    ))
  }
</nav>

{/* Mobile hamburger menu (visible only on narrow viewports) */}
<button
  type="button"
  id="mobile-nav-trigger"
  class="md:hidden p-2 rounded-sm text-ink-muted hover:text-ink hover:bg-paper-raised transition-colors"
  aria-label="Open menu"
  aria-controls="mobile-nav-panel"
  aria-expanded="false"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
    <line x1="3" y1="6" x2="21" y2="6"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
    <line x1="3" y1="18" x2="21" y2="18"></line>
  </svg>
</button>

<div
  id="mobile-nav-panel"
  class="md:hidden hidden fixed inset-x-0 top-[var(--header-height)] z-30 bg-paper border-b border-rule shadow-lg"
>
  <ul class="container-page py-4 space-y-1">
    {
      navigation.map((item) => (
        <li>
          <a
            href={item.href}
            title={item.description}
            class:list={[
              'block px-3 py-2.5 text-sm font-medium rounded-sm transition-colors',
              isActive(item.href)
                ? 'text-ink bg-paper-raised'
                : 'text-ink-muted hover:text-ink hover:bg-paper-raised/60',
            ]}
          >
            <span class="block font-display font-semibold tracking-[-0.012em]">{item.label}</span>
            {item.description && (
              <span class="block text-xs text-ink-subtle mt-0.5 font-normal">{item.description}</span>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script>
  function initMobileNav() {
    const trigger = document.getElementById('mobile-nav-trigger');
    const panel = document.getElementById('mobile-nav-panel');
    if (!trigger || !panel) return;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const willOpen = panel.classList.contains('hidden');
      panel.classList.toggle('hidden', !willOpen);
      trigger.setAttribute('aria-expanded', String(willOpen));
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      const t = e.target as Node;
      if (panel.classList.contains('hidden')) return;
      if (trigger.contains(t) || panel.contains(t)) return;
      panel.classList.add('hidden');
      trigger.setAttribute('aria-expanded', 'false');
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) {
        panel.classList.add('hidden');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    // Close on navigation (view-transition aware)
    document.addEventListener('astro:page-load', () => {
      panel.classList.add('hidden');
      trigger.setAttribute('aria-expanded', 'false');
    });
  }

  initMobileNav();
  document.addEventListener('astro:page-load', initMobileNav);
</script>
