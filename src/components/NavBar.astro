---
import { navigation } from '../config';

const currentPath = Astro.url.pathname;
const isActive = (href: string): boolean =>
  currentPath === href || currentPath.startsWith(`${href}/`);
---

<nav aria-label="Primary" class="hidden md:flex items-center gap-0.5">
  {
    navigation.map((item) => (
      <a
        href={item.href}
        title={item.description}
        class:list={[
          'px-3 py-2 text-sm font-medium rounded-sm transition-colors',
          item.variant === 'cta'
            ? 'bg-gold-deep text-white hover:bg-gold ml-2 dark:bg-gold dark:text-ink dark:hover:bg-gold-bright'
            : isActive(item.href)
              ? 'text-ink bg-paper-raised'
              : 'text-ink-muted hover:text-ink hover:bg-paper-raised/60',
        ]}
      >
        {item.label}
      </a>
    ))
  }
</nav>

{/* Mobile hamburger menu (visible only on narrow viewports) */}
<button
  type="button"
  class="mobile-nav-trigger md:hidden p-2 rounded-sm text-ink-muted hover:text-ink hover:bg-paper-raised transition-colors relative z-50"
  aria-label="Open menu"
  aria-controls="mobile-nav-panel"
  aria-expanded="false"
  onclick="window.__toggleMobileNav && window.__toggleMobileNav()"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
    <line x1="3" y1="6" x2="21" y2="6"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
    <line x1="3" y1="18" x2="21" y2="18"></line>
  </svg>
</button>

<div
  id="mobile-nav-panel"
  class="md:hidden hidden fixed inset-x-0 top-[var(--header-height)] z-40 bg-paper border-b border-rule shadow-lg"
>
  <ul class="container-page py-4 space-y-1">
    {
      navigation.map((item) => (
        <li>
          <a
            href={item.href}
            title={item.description}
            class:list={[
              'block px-3 py-2.5 text-sm font-medium rounded-sm transition-colors',
              item.variant === 'cta'
                ? 'bg-gold-deep text-white hover:bg-gold dark:bg-gold dark:text-ink dark:hover:bg-gold-bright'
                : isActive(item.href)
                  ? 'text-ink bg-paper-raised'
                  : 'text-ink-muted hover:text-ink hover:bg-paper-raised/60',
            ]}
          >
            <span class="block font-display font-semibold tracking-[-0.012em]">{item.label}</span>
            {item.description && (
              <span class="block text-xs text-ink-subtle mt-0.5 font-normal">{item.description}</span>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script is:inline>
  // Global toggle function — defined once on initial load, called via
  // onclick attribute on the hamburger button. Using is:inline so the
  // script isn't bundled (which can fail to re-bind after Astro view
  // transitions replace the DOM).
  (function () {
    function toggle() {
      const panel = document.getElementById('mobile-nav-panel');
      const trigger = document.querySelector('.mobile-nav-trigger');
      if (!panel || !trigger) return;
      const willOpen = panel.classList.contains('hidden');
      panel.classList.toggle('hidden', !willOpen);
      trigger.setAttribute('aria-expanded', String(willOpen));
    }
    window.__toggleMobileNav = toggle;

    function close() {
      const panel = document.getElementById('mobile-nav-panel');
      const trigger = document.querySelector('.mobile-nav-trigger');
      if (!panel || !trigger) return;
      panel.classList.add('hidden');
      trigger.setAttribute('aria-expanded', 'false');
    }

    // Close on outside click — but only if click is outside both
    // trigger and panel.
    document.addEventListener('click', function (e) {
      const panel = document.getElementById('mobile-nav-panel');
      const trigger = document.querySelector('.mobile-nav-trigger');
      if (!panel || panel.classList.contains('hidden')) return;
      const t = e.target;
      if (trigger && trigger.contains(t)) return;
      if (panel.contains(t)) return;
      close();
    });

    // Close on Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') close();
    });

    // Close on view-transition navigation
    document.addEventListener('astro:page-load', close);
  })();
</script>
