---
import { navigation } from '../config';
import Icon from './Icon.astro';

const currentPath = Astro.url.pathname;
const isActive = (href: string): boolean =>
  currentPath === href || currentPath.startsWith(`${href}/`);
---

<nav aria-label="Primary" class="hidden md:flex items-center gap-0.5">
  {
    navigation.map((item) => (
      <a
        href={item.href}
        title={item.description}
        class:list={[
          'px-3 py-2 text-sm font-medium rounded-sm transition-colors',
          item.variant === 'cta'
            ? 'nav-cta ml-2'
            : isActive(item.href)
              ? 'text-ink bg-paper-raised'
              : 'text-ink-muted hover:text-ink hover:bg-paper-raised/60',
        ]}
      >
        {item.label}
      </a>
    ))
  }
</nav>

{/* Mobile hamburger menu (visible only on narrow viewports) */}
<button
  type="button"
  id="mobile-nav-trigger"
  class="md:hidden p-2 rounded-sm text-ink-muted hover:text-ink hover:bg-paper-raised transition-colors relative z-50"
  aria-label="Open menu"
  aria-controls="mobile-nav-panel"
  aria-expanded="false"
>
  <Icon name="menu" size={20} />
</button>

<div
  id="mobile-nav-panel"
  class="md:hidden hidden fixed inset-x-0 top-[var(--header-height)] z-40 bg-paper border-b border-rule shadow-lg"
>
  <ul class="container-page py-4 space-y-1">
    {
      navigation.map((item) => (
        <li>
          <a
            href={item.href}
            title={item.description}
            class:list={[
              'block px-3 py-2.5 text-sm font-medium rounded-sm transition-colors',
              item.variant === 'cta'
                ? 'nav-cta'
                : isActive(item.href)
                  ? 'text-ink bg-paper-raised'
                  : 'text-ink-muted hover:text-ink hover:bg-paper-raised/60',
            ]}
          >
            <span class="block font-display font-semibold tracking-[-0.012em]">{item.label}</span>
            {item.description && (
              <span class="block text-xs text-ink-subtle mt-0.5 font-normal">{item.description}</span>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script is:inline>
  // Mobile nav toggle. Inline because Astro view transitions replace
  // the DOM, so a bundled <script> might miss the re-rendered trigger.
  // We look up the trigger by id each call rather than relying on a
  // global function called via inline onclick.
  (function () {
    function getEls() {
      const panel = document.getElementById('mobile-nav-panel');
      const trigger = document.getElementById('mobile-nav-trigger');
      return { panel, trigger };
    }

    function toggle() {
      const { panel, trigger } = getEls();
      if (!panel || !trigger) return;
      const willOpen = panel.classList.contains('hidden');
      panel.classList.toggle('hidden', !willOpen);
      trigger.setAttribute('aria-expanded', String(willOpen));
    }

    function close() {
      const { panel, trigger } = getEls();
      if (!panel || !trigger) return;
      panel.classList.add('hidden');
      trigger.setAttribute('aria-expanded', 'false');
    }

    function bindTrigger() {
      const trigger = document.getElementById('mobile-nav-trigger');
      if (!trigger || trigger.dataset.bound) return;
      trigger.dataset.bound = '1';
      trigger.addEventListener('click', toggle);
    }

    bindTrigger();

    // Close on outside click — but only if click is outside both
    // trigger and panel.
    document.addEventListener('click', function (e) {
      const { panel, trigger } = getEls();
      if (!panel || panel.classList.contains('hidden')) return;
      if (trigger && trigger.contains(e.target)) return;
      if (panel.contains(e.target)) return;
      close();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') close();
    });

    // Re-bind after view transitions
    document.addEventListener('astro:page-load', () => { bindTrigger(); close(); });
  })();
</script>
