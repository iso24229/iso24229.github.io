---
import { operatingAuthorities, repoUrls, externalLinks, siteTitle } from '../config';
import OutwardLink from './OutwardLink.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-surface-raised mt-16">
  <div class="container-page py-12 grid gap-10 md:grid-cols-[2fr_1fr_1fr]">
    <div>
      <p class="text-sm font-semibold mb-2">{siteTitle}</p>
      <p class="text-sm text-ink-muted max-w-md">
        Designated under
        <a href={externalLinks.iso24229Standard} class="underline" rel="noopener">ISO 24229</a>
        by ISO/TC 46/WG 3. Operated as an
        <a href={externalLinks.iso19135Standard} class="underline" rel="noopener">ISO 19135</a>
        register.
      </p>
      <p class="text-xs text-ink-subtle mt-4">
        © {year} International Organization for Standardization. All rights reserved.
      </p>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-ink-subtle mb-3">Operated by</p>
      <ul class="space-y-3">
        {
          operatingAuthorities.map((org) => (
            <li>
              <a
                href={org.href}
                target="_blank"
                rel="noopener"
                class="flex items-start gap-3 group"
                title={`${org.name} — ${org.role}`}
              >
                <img
                  src={org.logo.light}
                  alt={`${org.name} logo`}
                  class="hidden dark:block h-8 w-auto"
                  width="120"
                  height="32"
                />
                <img
                  src={org.logo.dark}
                  alt={`${org.name} logo`}
                  class="block dark:hidden h-8 w-auto"
                  width="120"
                  height="32"
                />
                <span class="text-xs text-ink-muted leading-tight">{org.role}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-ink-subtle mb-3">Source</p>
      <ul class="space-y-1.5 text-sm">
        <li><OutwardLink href={repoUrls.website}>Website source</OutwardLink></li>
        <li><OutwardLink href={repoUrls.register}>Register data</OutwardLink></li>
        <li><OutwardLink href={repoUrls.iso639Data}>ISO 639 reference</OutwardLink></li>
        <li><OutwardLink href={repoUrls.iso15924Data}>ISO 15924 reference</OutwardLink></li>
      </ul>
    </div>
  </div>
</footer>
