---
import { lookupScript, lookupLanguage } from '../domain/codes/CodeNames';

interface Props {
  kind: 'language' | 'script';
  code: string;
  /** Optional href to override the default (e.g. link to /register/iso639/<code>). */
  codeHref?: string;
}

const { kind, code, codeHref } = Astro.props;

const scriptInfo = kind === 'script' ? lookupScript(code) : null;
const langInfo = kind === 'language' ? lookupLanguage(code) : null;
const info = scriptInfo ?? langInfo;
const partLabel = langInfo ? `ISO 639 (${langInfo.part})` : 'ISO 15924';
const standardLabel = kind === 'script' ? 'ISO 15924' : 'ISO 639';
---

<span class="inline-flex flex-wrap items-baseline gap-x-2 align-baseline">
  {codeHref ? (
    <a href={codeHref} class="font-mono text-sm text-blue dark:text-blue-bright hover:underline">{code}</a>
  ) : (
    <span class="font-mono text-sm text-ink">{code || '—'}</span>
  )}
  {info && (
    <span class="text-sm text-ink-muted">{info.name}</span>
  )}
  {info && (
    <a
      href={info.url}
      target="_blank"
      rel="noopener"
      class="text-xs text-ink-subtle hover:text-gold-deep dark:hover:text-gold-bright underline"
    >
      {partLabel}
      <span aria-hidden="true" class="ml-0.5">↗</span>
    </a>
  )}
  {!info && code && (
    <span class="text-xs text-ink-subtle italic">{standardLabel} (unknown)</span>
  )}
</span>
