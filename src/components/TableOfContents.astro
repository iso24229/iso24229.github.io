---
/**
 * Sticky table of contents for multi-section pages.
 * Renders a left-sidebar nav with links to section IDs.
 *
 * Usage:
 * <TableOfContents items={[{id: 'purpose', label: 'Purpose'}, ...]} />
 * <div class="lg:grid lg:grid-cols-[180px_1fr] lg:gap-12">
 *   <TableOfContents items={tocItems} />
 *   <div class="max-w-2xl">
 *     ... page content with matching section IDs ...
 *   </div>
 * </div>
 */
export interface TocItem {
  id: string;
  label: string;
}

export interface Props {
  items: TocItem[];
}

const { items } = Astro.props;
---

<aside class="hidden lg:block">
  <div class="sticky top-[calc(var(--header-height)+1.5rem)]">
    <p class="eyebrow mb-3">On this page</p>
    <ul class="space-y-1.5 text-sm">
      {items.map((item) => (
        <li>
          <a
            href={`#${item.id}`}
            class="block py-1 border-l-2 border-rule pl-3 text-ink-muted hover:text-ink hover:border-gold-deep dark:hover:border-gold-bright transition-colors"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</aside>
