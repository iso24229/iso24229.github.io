---
// Theme toggle button. Theme application lives in Layout.astro <head>
// (so it runs before first paint and survives Astro view transitions).
---

<button
  id="theme-control"
  type="button"
  aria-label="Toggle dark mode"
  class="p-2 rounded-sm text-ink-muted hover:text-ink hover:bg-paper-raised transition-colors"
>
  <svg class="dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M5 19l1.5-1.5M17.5 6.5L19 5" />
  </svg>
  <svg class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
    <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z" />
  </svg>
</button>

<script>
  function wire() {
    document.getElementById('theme-control')?.addEventListener('click', () => {
      const root = document.documentElement;
      const next = root.classList.contains('dark') ? 'light' : 'dark';
      root.classList.toggle('dark', next === 'dark');
      root.dataset.theme = next;
      localStorage.setItem('theme', next);
    });
  }
  wire();
  document.addEventListener('astro:after-swap', wire);
</script>
