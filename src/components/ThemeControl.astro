---
import Icon from './Icon.astro';
// Theme toggle button. Theme application lives in Layout.astro <head>
// (so it runs before first paint and survives Astro view transitions).
---

<button
  id="theme-control"
  type="button"
  aria-label="Toggle dark mode"
  class="p-2 rounded-sm text-ink-muted hover:text-ink hover:bg-paper-raised transition-colors"
>
  <Icon name="sun" class="dark:hidden" />
  <Icon name="moon" class="hidden dark:block" />
</button>

<script>
  function wire() {
    document.getElementById('theme-control')?.addEventListener('click', () => {
      const root = document.documentElement;
      const next = root.classList.contains('dark') ? 'light' : 'dark';
      root.classList.toggle('dark', next === 'dark');
      root.dataset.theme = next;
      localStorage.setItem('theme', next);
    });
  }
  wire();
  document.addEventListener('astro:after-swap', wire);
</script>
