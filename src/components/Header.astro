---
import NavBar from './NavBar.astro';
import ThemeControl from './ThemeControl.astro';
---

<header class="border-b border-rule bg-paper/95 backdrop-blur sticky top-0 z-40">
  <div class="container-page flex items-center justify-between h-[var(--header-height)] gap-6">
    <a href="/" rel="prefetch-intent" class="flex items-center gap-3 group" title="ISO 24229 register — home">
      <img
        src="/assets/logos/iso-24229-logo.svg"
        alt="ISO 24229 logomark"
        width="40"
        height="40"
        class="block shrink-0 w-10 h-10"
      />
      <span class="flex flex-col leading-none">
        <span class="font-display font-bold text-[1.45rem] leading-none tracking-[-0.045em] text-ink whitespace-nowrap">
          ISO 24229
        </span>
        <span class="mt-1 font-display text-[0.625rem] font-semibold tracking-[0.24em] uppercase text-ink-subtle whitespace-nowrap">
          Registry · RA
        </span>
      </span>
    </a>
    <div class="flex items-center gap-1">
      <NavBar />
      <ThemeControl />
    </div>
  </div>
</header>
