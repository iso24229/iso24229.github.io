---
import NavBar from './NavBar.astro';
import ThemeControl from './ThemeControl.astro';
---

<header class="border-b border-rule bg-paper/95 backdrop-blur sticky top-0 z-40">
  <div class="container-page flex items-center justify-between h-[var(--header-height)] gap-6">
    <a href="/" rel="prefetch-intent" class="flex items-center gap-3 group" title="ISO 24229 register — home">
      <img
        src="/assets/logos/iso-24229-logo.svg"
        alt="ISO 24229 logomark"
        width="36"
        height="36"
        class="block"
      />
      <span class="font-display text-xl font-semibold tracking-tight leading-none">
        ISO 24229
        <span class="text-ink-subtle font-normal italic">Registry</span>
      </span>
    </a>
    <div class="flex items-center gap-1">
      <NavBar />
      <ThemeControl />
    </div>
  </div>
</header>
