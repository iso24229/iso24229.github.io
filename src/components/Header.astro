---
import NavBar from './NavBar.astro';
import ThemeControl from './ThemeControl.astro';
---

<header class="border-b border-rule bg-paper/95 backdrop-blur sticky top-0 z-40">
  <div class="container-page flex items-center justify-between h-[var(--header-height)] gap-6">
    <a href="/" rel="prefetch-intent" class="flex items-center gap-3.5 group" title="ISO 24229 register — home">
      <img
        src="/assets/logos/iso-24229-logo.svg"
        alt="ISO 24229 logomark"
        width="36"
        height="36"
        class="block shrink-0"
      />
      <span class="flex items-baseline gap-2.5 leading-none">
        <span class="font-display font-bold text-[1.35rem] tracking-[-0.04em] text-ink whitespace-nowrap">
          ISO&nbsp;24229
        </span>
        <span aria-hidden="true" class="hidden sm:inline-block w-px h-4 bg-rule"></span>
        <span class="hidden sm:inline font-display text-[0.625rem] font-semibold tracking-[0.22em] uppercase text-ink-subtle whitespace-nowrap">
          Registry
        </span>
      </span>
    </a>
    <div class="flex items-center gap-1">
      <NavBar />
      <ThemeControl />
    </div>
  </div>
</header>
