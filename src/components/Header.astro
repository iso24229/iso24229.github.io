---
import NavBar from './NavBar.astro';
import ThemeControl from './ThemeControl.astro';
import { siteTitle } from '../config';
---

<header class="border-b border-line bg-surface/95 backdrop-blur sticky top-0 z-40">
  <div class="container-page flex items-center justify-between h-[var(--header-height)] gap-6">
    <a href="/" rel="prefetch-intent" class="flex items-center gap-3 group" title="Back to home">
      <img
        src="/assets/logos/iso-red.svg"
        alt="ISO"
        width="40"
        height="40"
        class="block"
      />
      <div class="flex flex-col leading-tight">
        <span class="font-semibold text-lg tracking-tight">
          ISO 24229
          <span class="text-ink-subtle font-normal">Registry</span>
        </span>
        <span class="text-xs text-ink-subtle">
          {siteTitle}
        </span>
      </div>
    </a>
    <div class="flex items-center gap-2">
      <NavBar />
      <ThemeControl />
    </div>
  </div>
</header>
