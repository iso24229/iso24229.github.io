---
export interface Props {
  href: string;
  title: string;
  body?: string;
  audience?: string;
}
const { href, title, body = '', audience } = Astro.props;
---

<a href={href} class="card-link group block">
  <div class="flex items-baseline justify-between gap-4">
    <h2 class="text-xl font-semibold tracking-tight">{title}</h2>
    <span class="text-ink-subtle group-hover:text-accent transition-colors" aria-hidden="true">→</span>
  </div>
  {body && <p class="mt-2 text-sm text-ink-muted">{body}</p>}
  {
    audience && (
      <p class="mt-3 text-xs uppercase tracking-wide text-ink-subtle">{audience}</p>
    )
  }
  <slot />
</a>
