---
export interface Props {
  href: string;
  title: string;
  body?: string;
  audience?: string;
}
const { href, title, body = '', audience } = Astro.props;
---

<a href={href} class="card-link group block">
  <div class="flex items-baseline justify-between gap-4">
    <h3 class="font-display text-xl font-semibold tracking-tight">{title}</h3>
    <span class="text-ink-subtle group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors" aria-hidden="true">→</span>
  </div>
  {body && <p class="mt-2 text-sm text-ink-muted leading-relaxed">{body}</p>}
  {
    audience && (
      <p class="mt-3 eyebrow">{audience}</p>
    )
  }
  <slot />
</a>
