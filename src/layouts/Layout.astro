---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { siteTitle, siteDescription } from '../config';

export interface Props {
  title?: string;
  description?: string;
  /** Render the page in a constrained content column (default true). */
  constrained?: boolean;
}

const { title = '', description = siteDescription, constrained = true } = Astro.props;

const pageTitle = title === '' ? siteTitle : `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png?v=20260708" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260708" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260708" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=20260708" />
    <link rel="manifest" href="/site.webmanifest?v=20260708" />
    <meta name="robots" content="none" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <GoogleAnalytics />
    <ClientRouter />
    {/* Theme must be applied BEFORE first paint to avoid FOUC, and
        re-applied after every Astro view transition. */}
    <script is:inline>
      (function () {
        const root = document.documentElement;
        const stored = localStorage.getItem('theme');
        const prefersDark = matchMedia('(prefers-color-scheme: dark)').matches;
        const initial = stored ?? (prefersDark ? 'dark' : 'light');
        const apply = (t) => {
          root.classList.toggle('dark', t === 'dark');
          root.dataset.theme = t;
        };
        apply(initial);

        document.addEventListener('astro:after-swap', () => apply(localStorage.getItem('theme') ?? initial));
        document.addEventListener('astro:before-swap', (e) => {
          const t = localStorage.getItem('theme') ?? initial;
          e.newDocument.documentElement.classList.toggle('dark', t === 'dark');
          e.newDocument.documentElement.dataset.theme = t;
        });
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-paper text-ink antialiased">
    <Header />
    <main class={constrained ? 'container-page flex-1 py-10' : 'flex-1'}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
