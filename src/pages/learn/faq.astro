---
import Layout from '../../layouts/Layout.astro';

interface FaqItem {
  q: string;
  a: string;
}

const sections: { title: string; items: FaqItem[] }[] = [
  {
    title: 'General',
    items: [
      { q: 'Why does ISO 24229 exist?', a: 'To give every writing system conversion system — transliteration, transcription, romanisation, and same-script orthographic changes alike — a single unambiguous identifier. A library catalogue in Tokyo, a gazetteer in Canberra, and a corpus in Berkeley might all reference the same system under different names. ISO 24229 eliminates that ambiguity.' },
      { q: 'What does "writing system conversion" cover?', a: 'Any transformation of written text from one spelling system to another. This includes script conversion (transliteration, transcription, romanisation) and conversion within the same script (re-spelling foreign names, orthographic reform). If text changes form — even without changing script — ISO 24229 can identify the rules used.' },
      { q: 'How is this different from ISO 639 or ISO 15924?', a: 'ISO 639 identifies languages. ISO 15924 identifies scripts. ISO 24229 identifies the systems that convert between them. The three standards compose: a single ISO 24229 code cites ISO 639 and ISO 15924 codes inside its own structure.' },
      { q: 'Is this the same as BCP 47?', a: 'No. BCP 47 composes language tags from ISO 639 + ISO 15924 + ISO 3166 codes — it identifies a language variant, not a conversion method. ISO 24229 answers a different question: given two variants, which system was used to convert between them?' },
      { q: 'Who maintains the register?', a: 'CalConnect is the Registration Authority (ISO 24229/RA), designated by ISO. The register is operated by Ribose. An Advisory Group (ISO 24229/AG) of 4–12 experts reviews submissions.' },
      { q: 'How does the Advisory Group decide?', a: 'By consensus as a rule. If a vote is needed, a decision requires more than two-thirds of members to approve.' },
      { q: 'Is the register free to use?', a: 'Yes. The register data is open. The standard itself (ISO 24229) is sold by ISO.' },
      { q: 'Where does the data come from?', a: 'The register lives at github.com/iso24229/register. ISO 639 and ISO 15924 reference data is auto-synced weekly from the Library of Congress, SIL, and the Unicode Consortium.' },
    ],
  },
  {
    title: 'For users',
    items: [
      { q: 'How do I find a conversion system?', a: 'Browse Content from the top nav. Each entry shows the source and target spelling, the authority, the lifecycle status, and related systems.' },
      { q: 'What does a code like `UN:ara-Arab:Latn:2017` mean?', a: 'Four colon-separated segments: UN (United Nations, the authority), ara-Arab (Arabic language in Arabic script, the source), Latn (Latin script, the target), 2017 (year of adoption, the identifier).' },
      { q: 'What about systems with no clear authority?', a: 'The Varia (Var) authority is managed by the AG for systems that need representation but have no extant authority. Example: Var:zho-Hani:Latn:WG-1912 for Wade-Giles.' },
      { q: 'Can I rely on proposed codes in production?', a: 'Proposed codes are pending AG review and may change. Preferred codes are stable — their identifiers are reserved forever, even if later deprecated.' },
      { q: 'How do I cite a register entry?', a: 'Cite the code and the access date. Example: `acadsin:zho-Hani:Latn:2002, ISO 24229 register, accessed YYYY-MM-DD`.' },
      { q: 'Can I get the data in bulk?', a: 'Yes. JSON-LD, Turtle, and RDF/XML dumps are at /data/register.{jsonld,ttl,rdf}. Per-item downloads are available from each entry\'s page.' },
      { q: 'What if my language or script is not in ISO 639 or ISO 15924?', a: 'Apply to the relevant Registration Authority first (LOC for ISO 639-2/-5, SIL for ISO 639-3, Unicode Consortium for ISO 15924). ISO 24229 codes can only reference codes that already exist in those standards.' },
    ],
  },
  {
    title: 'For authorities',
    items: [
      { q: 'How do I add a new system?', a: 'Open a registration issue from the Apply section. You need source/target ISO 639 and ISO 15924 codes, a specification document, real-world usage evidence, and a justification. The /apply/validate/ page checks your codes first.' },
      { q: 'My authority is not listed. How do we join?', a: 'Apply via the New authority path. The standard requires the authority to be a competent, recognised institution with standardised management processes.' },
      { q: 'How long does approval take?', a: 'Submissions are batched onto the next AG meeting agenda. With the bimonthly cadence, typically 8–10 weeks.' },
      { q: 'Can we update an existing code?', a: 'Yes — file an issue referencing the existing code. Material changes (e.g. authority rename) may require deprecating the old code and registering a successor. Typo fixes can be made in place.' },
      { q: 'How do I request deprecation?', a: 'Open an issue with the deprecation label. Deprecated codes are reserved forever — never reused.' },
    ],
  },
];
---

<Layout title="FAQ">
  <section class="mb-10">
    <p class="eyebrow mb-4">FAQ</p>
    <h1 class="mb-4">Frequently asked questions.</h1>
    <p class="text-lg text-ink-muted max-w-2xl leading-relaxed">
      Common questions about ISO 24229, the register, and how to participate. For deeper context, see the <a href="/learn" class="underline">Learn</a> section.
    </p>
  </section>

  <div class="grid gap-12 lg:grid-cols-[180px_1fr]">
    <aside class="hidden lg:block">
      <div class="sticky top-[calc(var(--header-height)+1.5rem)]">
        <p class="eyebrow mb-3">On this page</p>
        <ul class="space-y-1.5 text-sm">
          {sections.map((s, i) => (
            <li>
              <a href={`#section-${i}`} class="block py-1 border-l-2 border-rule pl-3 text-ink-muted hover:text-ink hover:border-gold-deep dark:hover:border-gold-bright transition-colors">{s.title}</a>
            </li>
          ))}
        </ul>
      </div>
    </aside>

    <div class="max-w-2xl">
      {sections.map((section, si) => (
        <section id={`section-${si}`} class={si > 0 ? 'mt-12 pt-8 border-t border-rule' : ''}>
          <h2 class="text-xl font-semibold tracking-tight mb-6">{section.title}</h2>
          <dl class="space-y-8">
            {section.items.map((item) => (
              <div>
                <dt class="text-base font-medium mb-2">{item.q}</dt>
                <dd class="text-ink-muted leading-relaxed">{item.a}</dd>
              </div>
            ))}
          </dl>
        </section>
      ))}
    </div>
  </div>
</Layout>
