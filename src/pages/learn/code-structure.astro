---
import Layout from '../../layouts/Layout.astro';
import { externalLinks } from '../../config';

const specExamples = [
  { n: 1, code: 'UN:ara-Arab:Latn:2017', abbrev: 'UN:ara:Latn:2017', desc: 'United Nations system for the romanization of Arabic, approved 2017.' },
  { n: 2, code: 'UN:mon-Mong-CN:Latn:1977', abbrev: 'UN:mon-CN:Latn:1977', desc: 'United Nations system for the romanization of Mongolian in China, approved 1977.' },
  { n: 3, code: 'BGN-PCGN:chn-Hans:Latn:1979', desc: 'BGN/PCGN 1979 Agreement — Romanization of Chinese.' },
  { n: 4, code: 'ALA-LC:mal-Mlym:Latn:2012', abbrev: 'ALA-LC:mal:Latn:2012', desc: 'ALA-LC romanization system that transliterates the Malayalam language from Malayalam script characters into Latin script.' },
  { n: 5, code: 'ISO:Cyrl:Latn:9-1995', desc: 'ISO 9:1995 for the transliteration into Latin of Cyrillic characters.' },
  { n: 6, code: 'ICAO:Arab:Latn:2015', desc: 'ICAO rules for rendering Arabic-script names in Latin letters, issued in 2015.' },
  { n: 7, code: 'DIN:bel-Cyrl:Latn:1460-1982', abbrev: 'DIN:bel:Latn:1460-1982', desc: 'DIN 1460 for the transliteration of Belarusian into Latin.' },
  { n: 8, code: 'ESKT:udm-Cyrl:est-Latn:2021', abbrev: 'ESKT:udm:est:2021', desc: 'Estonian Language Committee\'s rules for rendering Udmurt names in Estonian texts, approved 2021.' },
  { n: 9, code: 'LV:eng-Latn:lav-Latn:2006', abbrev: 'LV:eng:lav:2006', desc: 'Official instructions in Latvia on rendering English proper names in Latvian, issued in 2006.' },
];

const spellingExamples = [
  { code: 'ind-Latn-pre1972', desc: 'Indonesian language using the pre-1972 orthography' },
  { code: 'bos-Arab', desc: 'Bosnian language using Arabic script' },
  { code: 'uzb-Arab-AF', desc: 'Uzbek language as used in Afghanistan' },
];

const authorityExamples = [
  { id: 'ISO', name: 'International Organization for Standardization' },
  { id: 'BGN-PCGN', name: 'United States Board on Geographic Names — Permanent Committee on Geographical Names for British Official Use' },
  { id: 'ALA-LC', name: 'American Library Association — Library of Congress' },
  { id: 'DIN', name: 'German Institute for Standardization' },
  { id: 'ICAO', name: 'International Civil Aviation Organization' },
  { id: 'UN', name: 'United Nations' },
];
---

<Layout title="Conversion system codes">
  <p class="text-sm text-ink-subtle mb-2"><a href="/learn">← Learn</a></p>
  <h1 class="text-4xl font-semibold tracking-tight mb-6">Conversion system codes</h1>

  <p class="text-lg text-ink-muted max-w-2xl mb-10 leading-relaxed">
    Every written language conversion system in the register receives a unique code constructed from four colon-separated segments. This page covers the complete structure, construction rules, and all sub-clauses of §4 of ISO 24229.
  </p>

  {/* ── §4.1 Structure ──────────────────────────────────────── */}
  <section class="mb-12">
    <p class="eyebrow mb-3">§4.1 Structure</p>
    <h2 class="mb-4">Four segments.</h2>
    <p class="text-ink-muted max-w-2xl leading-relaxed mb-6">
      A conversion system code consists of four segments, each containing one or more elements:
    </p>
    <div class="p-6 md:p-8 border border-rule rounded bg-paper-raised mb-6">
      <p class="font-mono text-lg md:text-2xl lg:text-3xl break-all leading-tight mb-4">
        <span class="text-gold-deep dark:text-gold-bright">titular</span><span class="text-ink-subtle">:</span><span class="text-blue dark:text-blue-bright">source-spelling</span><span class="text-ink-subtle">:</span><span class="text-blue dark:text-blue-bright">target-spelling</span><span class="text-ink-subtle">:</span><span class="text-ink">identifying</span>
      </p>
    </div>
  </section>

  {/* ── §4.1.2 Construction rules ───────────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.1.2 Construction rules</p>
    <h2 class="mb-4">Permitted characters and separators.</h2>
    <div class="max-w-2xl space-y-4 text-ink-muted leading-relaxed">
      <p>Codes shall consist of elements from the following Unicode ranges only:</p>
      <ul class="list-disc pl-6 space-y-1.5">
        <li>DIGIT ZERO through DIGIT NINE (<span class="font-mono">U+0030 — U+0039</span>)</li>
        <li>LATIN CAPITAL LETTER A through LATIN CAPITAL LETTER Z (<span class="font-mono">U+0041 — U+005A</span>)</li>
        <li>LATIN SMALL LETTER A through LATIN SMALL LETTER Z (<span class="font-mono">U+0061 — U+007A</span>)</li>
      </ul>
      <p>Separation rules:</p>
      <ul class="list-disc pl-6 space-y-1.5">
        <li>Segments are separated by a single <strong>COLON</strong> (<span class="font-mono">:</span>, U+003A)</li>
        <li>Elements within a segment are separated by a single <strong>HYPHEN-MINUS</strong> (<span class="font-mono">-</span>, U+002D)</li>
        <li>HYPHEN-MINUS within an element (e.g. <span class="font-mono">9-1995</span>) is also accepted</li>
      </ul>
      <p>Other characters not covered by the above should be omitted or substituted.</p>
    </div>
  </section>

  {/* ── §4.1.3 Titular segment ──────────────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.1.3 Titular segment</p>
    <h2 class="mb-4">Who manages the system.</h2>
    <div class="max-w-2xl space-y-4 text-ink-muted leading-relaxed">
      <p>
        The titular segment contains a reference to the conversion system authority (or authorities) by using identifiers maintained by ISO 24229/RA. If an authority cannot be identified but the system has a national character or is used by a government, the 2-letter country code from ISO 3166-1 is used. If no authority can be identified, <span class="font-mono">Var</span> (varia) is used.
      </p>
      <p>
        See <a href="/learn/authorities" class="underline">Conversion system authorities</a> for the full set of rules governing authority identifiers.
      </p>
    </div>
  </section>

  {/* ── §4.1.4 Source spelling system ───────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.1.4 Source spelling system segment</p>
    <h2 class="mb-4">What is being converted from.</h2>
    <div class="max-w-2xl space-y-4 text-ink-muted leading-relaxed">
      <p>
        A script code is a mandatory element. Language-specific spelling systems also include a language code. Four elements, in order, may be used:
      </p>
      <div class="p-5 border border-rule rounded bg-paper-raised">
        <p class="font-mono text-base break-all mb-4">
          <span class="text-blue dark:text-blue-bright">languageCode</span>-<span class="text-blue dark:text-blue-bright">scriptCode</span>-<span class="text-ink-muted">countryCode</span>-<span class="text-ink-muted">extension</span>
        </p>
        <ul class="space-y-2 text-sm">
          <li><strong>languageCode</strong> — 3-letter code from <a href={externalLinks.iso639Standard} class="underline">ISO 639-2</a> or <a href={externalLinks.iso639Standard} class="underline">ISO 639-3</a>, with preference to terminological codes. ISO 639-2/T codes are intended for terminology applications.</li>
          <li><strong>scriptCode</strong> — 4-letter code from <a href={externalLinks.iso15924Standard} class="underline">ISO 15924</a></li>
          <li><strong>countryCode</strong> — 2-letter code from ISO 3166-1 (optional)</li>
          <li><strong>extension</strong> — ad hoc string for a non-default spelling system (optional, e.g. <span class="font-mono">pre1972</span> for old orthography)</li>
        </ul>
      </div>
    </div>
    <p class="eyebrow mt-6 mb-3">Examples from the standard</p>
    <div class="max-w-2xl space-y-2">
      {spellingExamples.map((ex) => (
        <p class="text-sm"><span class="font-mono text-blue dark:text-blue-bright">{ex.code}</span> <span class="text-ink-muted">— {ex.desc}</span></p>
      ))}
    </div>
  </section>

  {/* ── §4.1.5 Target spelling system ───────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.1.5 Target spelling system segment</p>
    <h2 class="mb-4">What is being converted into.</h2>
    <p class="text-ink-muted max-w-2xl leading-relaxed">
      The target segment may have the same four elements as the source. It can also be language-specific: <span class="font-mono text-sm">ESKT:udm-Cyrl:est-Latn:2021</span> denotes a system to represent Udmurt names in Estonian texts using the Estonian alphabet — not Latin as a whole.
    </p>
  </section>

  {/* ── §4.1.6 Identifying segment ──────────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.1.6 Identifying segment</p>
    <h2 class="mb-4">Which version, which year, which standard.</h2>
    <div class="max-w-2xl space-y-4 text-ink-muted leading-relaxed">
      <p>
        The identifying segment distinguishes conversion systems that otherwise have the same scope (same authority, source, and target). The following elements may occur, in order:
      </p>
      <ul class="list-disc pl-6 space-y-1.5">
        <li>Identifying numbers, letters, or else (e.g. standard number <span class="font-mono">843</span>)</li>
        <li>Version number (e.g. <span class="font-mono">v6</span>, <span class="font-mono">v4-1</span>)</li>
        <li>Year of adoption</li>
        <li>Year of issue</li>
        <li>Method identifier (if a standard devises more than one method of conversion)</li>
      </ul>
      <p>
        If no elements can be used, <span class="font-mono">na</span> (not applicable) is the substitute.
      </p>
      <p class="text-sm">
        Example: <span class="font-mono">2017</span> is the identifying segment of <span class="font-mono">UN:ara-Arab:Latn:2017</span>.
      </p>
    </div>
  </section>

  {/* ── §4.2 Requirements ───────────────────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.2 Requirements for new codes</p>
    <h2 class="mb-4">Eligibility criteria.</h2>
    <div class="max-w-2xl space-y-5 text-ink-muted leading-relaxed">
      <p>
        Additions to the register are made upon request from a member of ISO 24229/AG or the conversion system authority. The AG decides based on justification for actual requirements for international interchange.
      </p>
      <p>A written language conversion system is eligible if it fulfils <strong>one</strong> of:</p>
      <ul class="list-disc pl-6 space-y-1.5">
        <li>Approved for official use at some level of government</li>
        <li>Developed and used by educational/scientific institutions, published in a peer-reviewed scientific publication</li>
        <li>In substantial usage</li>
      </ul>
      <p>Assigning a code also requires demonstration of <strong>one</strong> of:</p>
      <ul class="list-disc pl-6 space-y-1.5">
        <li>Necessity of identification of the system in interchange</li>
        <li>Necessity of identification of the system in data encoding</li>
      </ul>
      <p class="text-sm text-ink-subtle">Note: systems used in isolation or only for temporary usage do not need assigned codes.</p>
    </div>
  </section>

  {/* ── §4.3 Deprecation ────────────────────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.3 Deprecation</p>
    <h2 class="mb-4">When codes are retired.</h2>
    <div class="max-w-2xl space-y-4 text-ink-muted leading-relaxed">
      <p>
        Deprecation of conversion system codes is made upon request from a member of ISO 24229/AG or the managing authority. The AG decides on the basis of information received. The corresponding code is reserved for backwards compatibility.
      </p>
      <p>
        Deprecation only applies to the code representation — not the system itself. For example, deprecation may be necessary when the authority undergoes a rename.
      </p>
    </div>
  </section>

  {/* ── §4.4 User-assigned ──────────────────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.4 User-assigned codes</p>
    <h2 class="mb-4">Codes for systems not in the register.</h2>
    <p class="text-ink-muted max-w-2xl leading-relaxed">
      If users need codes for systems not in the register, the prefix <span class="font-mono">zz</span> can be used at the beginning of the titular segment, followed by a hyphen-minus. These codes are not universally recognised and are not compatible between different entities.
    </p>
  </section>

  {/* ── §4.5 Capitalization ─────────────────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.5 Capitalization</p>
    <h2 class="mb-4">Case has no meaning.</h2>
    <p class="text-ink-muted max-w-2xl leading-relaxed">
      Codes use capitalization according to the relevant standards, but this has no distinctive meaning. An all-lowercase code is equally valid. For example, <span class="font-mono text-sm">iso:cyrl:latn:9-1995</span> and <span class="font-mono text-sm">ISO:Cyrl:Latn:9-1995</span> are identical codes.
    </p>
  </section>

  {/* ── §4.6 Abbreviated codes ──────────────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.6 Abbreviated codes</p>
    <h2 class="mb-4">Default scripts may be omitted.</h2>
    <p class="text-ink-muted max-w-2xl leading-relaxed">
      Abbreviated codes may be registered where script codes are omitted if they can be considered default scripts for the languages concerned. Sources such as the <a href="https://cldr.unicode.org/" class="underline" rel="noopener">Common Locale Data Repository (CLDR)</a> of the Unicode Consortium should be consulted when determining default scripts. See the examples in §4.7 below — each marked "possible abbreviation" demonstrates this principle.
    </p>
  </section>

  {/* ── §4.7 Examples ───────────────────────────────────────── */}
  <section class="rule-section mb-12">
    <p class="eyebrow mb-3">§4.7 Examples of conversion system codes</p>
    <h2 class="mb-4">Nine systems from the standard.</h2>
    <p class="text-sm text-ink-subtle mb-6">These examples are indicative and do not guarantee that such codes are registered.</p>
    <div class="max-w-2xl space-y-5">
      {specExamples.map((ex) => (
        <div class="border-l-2 border-rule pl-5">
          <p class="text-xs text-ink-subtle mb-1">Example {ex.n}</p>
          <p class="font-mono text-base md:text-lg break-all">
            <span class="text-gold-deep dark:text-gold-bright">{ex.code.split(':')[0]}</span><span class="text-ink-subtle">:</span><span class="text-blue dark:text-blue-bright">{ex.code.split(':')[1]}</span><span class="text-ink-subtle">:</span><span class="text-blue dark:text-blue-bright">{ex.code.split(':')[2]}</span><span class="text-ink-subtle">:</span><span class="text-ink">{ex.code.split(':')[3]}</span>
          </p>
          {ex.abbrev && (
            <p class="text-sm text-ink-subtle mt-1">Possible abbreviation: <span class="font-mono">{ex.abbrev}</span></p>
          )}
          <p class="text-sm text-ink-muted mt-1">{ex.desc}</p>
        </div>
      ))}
    </div>
    <p class="mt-6 text-sm text-ink-muted max-w-2xl">
      Target spelling systems can also be language-specific. Example 8 denotes a system to represent Udmurt names in Estonian texts using the Estonian alphabet, not Latin as a whole.
    </p>
  </section>

  <div class="rule-section flex flex-wrap gap-x-8 gap-y-3 text-sm">
    <a href="/learn/examples" class="text-ink-muted hover:text-gold-deep dark:hover:text-gold-bright">Worked examples with segment breakdowns →</a>
    <a href="/learn/authorities" class="text-ink-muted hover:text-gold-deep dark:hover:text-gold-bright">Conversion system authorities →</a>
    <a href="/specs/data-model" class="text-ink-muted hover:text-gold-deep dark:hover:text-gold-bright">Data model →</a>
  </div>
</Layout>
