---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
---

<Layout title="Learn">
  <h1 class="text-4xl font-semibold tracking-tight mb-4">Learn</h1>
  <p class="text-ink-muted max-w-2xl">
    ISO 24229 is the third part of a trio of standards that together let you
    identify <em>any</em> written form of any language. Start here if you're new.
  </p>

  <div class="mt-10 grid gap-4 md:grid-cols-2">
    <Card
      href="/learn/what-is-iso-24229"
      title="What is ISO 24229?"
      body="The trio: ISO 639 (language) → ISO 15924 (script) → ISO 24229 (conversion)."
    />
    <Card
      href="/learn/code-structure"
      title="Anatomy of a code"
      body="Four colon-separated segments: titular · source spelling · target spelling · identifying."
    />
    <Card
      href="/learn/examples"
      title="Worked examples"
      body="Real systems decoded, segment by segment."
    />
    <Card
      href="/learn/use-cases"
      title="Use cases"
      body="Where written language conversion shows up — libraries, gazetteers, i18n."
    />
    <Card
      href="/learn/glossary"
      title="Glossary"
      body="Defined terms from §3 of the standard — script, spelling system, transliteration, transcription, romanization."
    />
    <Card
      href="/learn/comparison"
      title="Comparison with related systems"
      body="How ISO 24229 relates to BCP 47, ALA-LC, ICAO 9303, UN systems, ISO 9."
    />
  </div>
</Layout>
