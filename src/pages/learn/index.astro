---
import Layout from '../../layouts/Layout.astro';
import ReadingPath from '../../components/ReadingPath.astro';

const foundations = [
  { n: 1, href: '/learn/introduction', title: 'Introduction', desc: 'The standard, its purpose, when you need it, and how it composes with ISO 639 and ISO 15924.', tag: 'Start here' },
  { n: 2, href: '/learn/code-structure', title: 'Conversion system codes', desc: 'Complete structure and construction rules from §4 — four segments, permitted characters, abbreviated forms.', tag: '§4' },
  { n: 3, href: '/learn/authorities', title: 'Conversion system authorities', desc: 'Requirements, competency, identifier construction rules, and examples from §5.', tag: '§5' },
];

const examples = [
  { n: 4, href: '/learn/examples', title: 'Worked examples', desc: 'Nine real systems from the standard, each with a segment breakdown and pattern analysis.' },
  { n: 5, href: '/learn/use-cases', title: 'Use cases', desc: 'Where writing system conversion shows up: libraries, gazetteers, passports, i18n, diplomacy.' },
];

const reference = [
  { n: 6, href: '/learn/glossary', title: 'Glossary', desc: 'Defined terms from §3: script, spelling system, transliteration, transcription, romanisation.' },
  { n: 7, href: '/learn/comparison', title: 'Comparison', desc: 'How ISO 24229 relates to BCP 47, ALA-LC, ICAO 9303, UN systems, ISO 9.' },
  { n: 8, href: '/faq', title: 'FAQ', desc: 'Common questions, briefly answered.' },
  { n: 9, href: '/specification', title: 'Specification', desc: 'Data model, governance, Annex A Terms of Reference, ISO 19135 compliance.' },
];
---

<Layout title="Learn">
  <section class="mb-12">
    <p class="eyebrow mb-4">Learn</p>
    <h1 class="max-w-3xl mb-6">Understand ISO 24229.</h1>
    <p class="text-lg text-ink-muted max-w-2xl leading-relaxed">
      A structured guide through the standard — from foundational concepts to worked examples to the full specification. Follow the path in order, or jump to any section.
    </p>
  </section>

  <section class="mb-12">
    <h2 class="text-xl font-semibold tracking-tight mb-2">Foundations</h2>
    <p class="text-sm text-ink-subtle mb-4">Start here if you're new to ISO 24229.</p>
    <ReadingPath items={foundations} />
  </section>

  <section class="rule-section mb-12">
    <h2 class="text-xl font-semibold tracking-tight mb-2">In practice</h2>
    <p class="text-sm text-ink-subtle mb-4">See the standard applied to real-world systems.</p>
    <ReadingPath items={examples} />
  </section>

  <section class="rule-section mb-12">
    <h2 class="text-xl font-semibold tracking-tight mb-2">Reference</h2>
    <p class="text-sm text-ink-subtle mb-4">Definitions, comparisons, and the formal specification.</p>
    <ReadingPath items={reference} />
  </section>
</Layout>
