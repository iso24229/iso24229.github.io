---
import Layout from '../../layouts/Layout.astro';
import { externalLinks } from '../../config';

const comparisons = [
  {
    name: 'BCP 47',
    body: 'BCP 47 composes a language tag (e.g. `zh-Hant-TW`) from ISO 639 + ISO 15924 + ISO 3166 codes. It identifies a language variant — not how to convert between variants. ISO 24229 picks up where BCP 47 leaves off: given two variants, which system do you use to convert between them?',
  },
  {
    name: 'ALA-LC romanization tables',
    body: 'The American Library Association / Library of Congress publishes romanization tables for many scripts. These are individual conversion systems; ISO 24229 gives each one a stable code (e.g. `ALA-LC:mal-Mlym:Latn:2012`) so they can be cited unambiguously in library systems.',
  },
  {
    name: 'ICAO Document 9303',
    body: 'ICAO 9303 specifies how to transliterate personal names in machine-readable travel documents. It is a major consumer of ISO 24229 codes — every ICAO system has a corresponding register entry.',
  },
  {
    name: 'UN romanization systems',
    body: 'The United Nations publishes recommended romanization systems for many geographic names. Each UN system has an ISO 24229 code (e.g. `UN:ara-Arab:Latn:2017`).',
  },
  {
    name: 'ISO 9 (Cyrillic)',
    body: 'ISO 9 itself is a standard that defines a Cyrillic→Latin transliteration. In ISO 24229 it gets the code `ISO:Cyrl:Latn:9-1995` — the standard number plus year is the identifying segment.',
  },
];
---

<Layout title="How ISO 24229 compares">
  <p class="text-sm text-ink-subtle"><a href="/learn">← Learn</a></p>
  <h1 class="text-4xl font-semibold tracking-tight mb-6">How ISO 24229 compares</h1>

  <p class="text-lg text-ink-muted max-w-2xl mb-10">
    ISO 24229 is the international standard for writing system conversion
    systems, composing with ISO 639 and ISO 15924. Other
    well-known standards and systems sit at different layers — most are
    <em>consumers</em> of ISO 24229 codes rather than competitors.
  </p>

  <div class="space-y-8 max-w-3xl">
    {
      comparisons.map((c) => (
        <section class="border-t border-line pt-6">
          <h2 class="text-xl font-semibold mb-2">{c.name}</h2>
          <p class="text-ink-muted">{c.body}</p>
        </section>
      ))
    }
  </div>

  <p class="mt-12">
    <a href={externalLinks.iso24229Standard} class="underline">Read the standard itself →</a>
  </p>
</Layout>
