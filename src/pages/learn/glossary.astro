---
import Layout from '../../layouts/Layout.astro';

const terms = [
  {
    term: 'script',
    def: 'A particular graphic representation or class of representations of a set of characters used to write one or more languages (ISO 5127). Each script has an ISO 15924 code.',
    examples: [['Latin', 'Latn'], ['Cyrillic', 'Cyrl'], ['Han / Hanzi / Kanji / Hanja', 'Hani'], ['Arabic', 'Arab']],
    note: null as string | null,
  },
  {
    term: 'spelling system',
    def: 'A set of rules governing the orthography of a language. Several languages have undergone orthographic reforms and thus have had multiple spelling systems over time.',
    examples: [['Indonesian pre-1972 orthography extension', 'pre1972'], ['Indonesian default orthography', 'ind-Latn']],
    note: 'A bare ISO 15924 script code (e.g. <code>Latn</code>) is NOT a spelling system — it has no language. Bare scripts live in ISO 15924 reference data only.' as string | null,
  },
  {
    term: 'written language',
    def: 'A natural language realized through the writing of characters. Identified by combining an ISO 639 language code with an ISO 15924 script code.',
    examples: [['Chinese in Han script', 'zho-Hani'], ['Arabic in Arabic script', 'ara-Arab']],
    note: null,
  },
  {
    term: 'writing system conversion',
    def: 'The process whereby one spelling system is converted into another. Includes change of language (e.g., rules for rendering proper names from another language in yours), script conversions within the same language (e.g., in Serbian between Latin and Cyrillic), and conversions within the same script (e.g., applying new orthography rules).',
    examples: [['Arabic-script Arabic → Latin', 'ara-Arab → Latn'], ['Serbian re-spelling between Latin and Cyrillic', 'srp-Latn → Cyrl']],
    note: null,
  },
  {
    term: 'transliteration',
    def: 'A conversion that represents the characters of an alphabetical or syllabic writing system by the characters of a conversion alphabet. Typically sign-by-sign reversible.',
    examples: [['ISO 9 (Cyrillic → Latin)', 'ISO:Cyrl:Latn:9-1995']],
    note: null,
  },
  {
    term: 'transcription',
    def: 'A conversion whereby the sounds of a given language are noted by the system of signs of a conversion language. Typically not reversible sign-by-sign.',
    examples: [['Wade-Giles Chinese transcription', 'Var:zho-Hani:Latn:WG-1912']],
    note: null,
  },
  {
    term: 'romanization',
    def: 'Script conversion from a non-Roman script to the Roman (Latin) script, by means of transliteration, transcription, or both.',
    examples: [['BGN/PCGN Chinese romanization', 'BGN-PCGN:zho-Hans:Latn:1979']],
    note: null,
  },
  {
    term: 'writing system conversion system',
    def: 'A set of rules for writing system conversion. Each system has a unique ISO 24229 code.',
    examples: [['UNGEGN Arabic romanisation', 'UN:ara-Arab:Latn:2017']],
    note: null,
  },
  {
    term: 'conversion system authority',
    def: 'A competent authority that creates, publishes, and/or manages writing system conversion systems. Has an alphabetic identifier (3–16 chars).',
    examples: [['United Nations', 'UN'], ['BGN/PCGN joint system', 'BGN-PCGN'], ['American Library Association / Library of Congress', 'ALA-LC']],
    note: null,
  },
  {
    term: 'Varia authority (Var)',
    def: 'A special authority managed by the Advisory Group for systems that need representation but do not have a clear extant authority.',
    examples: [['Wade-Giles Chinese transcription', `Var:zho-Hani:Latn:WG-1912`]],
    note: null,
  },
];
---

<Layout title="Glossary">
  <p class="text-sm text-ink-subtle"><a href="/learn">← Learn</a></p>
  <h1 class="text-4xl font-semibold tracking-tight mb-2">Glossary</h1>
  <p class="text-sm text-ink-subtle mb-10 max-w-2xl leading-relaxed">
    Definitions from §3 of ISO 24229, which itself sources many terms from ISO 5127. Examples and notes are editorial, intended to make the abstract definitions concrete.
  </p>

  <dl class="max-w-3xl">
    {terms.map((t, i) => (
      <div class="border-t border-rule py-8">
        <dt class="flex items-baseline gap-4 mb-3">
          <span class="font-mono text-xs text-ink-subtle tabular-nums">{String(i + 1).padStart(2, '0')}</span>
          <span class="font-display text-xl md:text-2xl font-semibold tracking-[-0.018em] text-ink">{t.term}</span>
        </dt>
        <dd class="pl-8">
          <p class="text-ink leading-relaxed max-w-2xl">{t.def}</p>
          {t.examples.length > 0 && (
            <div class="mt-5 border-l-2 border-gold/40 dark:border-gold-bright/40 pl-4">
              <p class="eyebrow text-gold-deep dark:text-gold-bright mb-2">Examples</p>
              <ul class="space-y-1">
                {t.examples.map(([explanation, code]) => (
                  <li class="text-sm text-ink-muted leading-relaxed">
                    <span class="text-ink break-all">{explanation}</span>
                    {code && (
                      <><span>: </span><span class="font-mono text-ink break-all">{code}</span></>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          )}
          {t.note && (
            <div class="mt-5 border-l-2 border-blue/40 dark:border-blue-bright/40 pl-4">
              <p class="eyebrow text-blue dark:text-blue-bright mb-2">Note</p>
              <p class="text-sm text-ink-muted leading-relaxed max-w-2xl" set:html={t.note} />
            </div>
          )}
        </dd>
      </div>
    ))}
  </dl>
</Layout>
