---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { externalLinks } from '../config';
---

<Layout>
  {/* ── Hero ─────────────────────────────────────────────────── */}
  <section class="mb-20 pt-8 md:pt-16">
    <p class="eyebrow mb-5">
      <a href={externalLinks.iso24229Standard} class="hover:text-gold-deep dark:hover:text-gold-bright">ISO 24229</a>
      · International Standard
    </p>

    <h1 class="max-w-4xl">
      The international standard for
      <span class="text-ink-subtle"> writing system conversion codes</span>.
    </h1>

    <p class="mt-8 text-lg md:text-xl text-ink-muted max-w-2xl leading-relaxed">
      ISO 24229 gives every system that converts text from one script or
      spelling to another — transliteration, transcription, romanization,
      and orthographic reform alike — a single, unambiguous identifier.
    </p>

    <p class="mt-5 text-base text-ink-muted max-w-2xl leading-relaxed">
      ISO 24229 composes with <a href={externalLinks.iso639Standard}>ISO 639</a> (language) and <a href={externalLinks.iso15924Standard}>ISO 15924</a> (script) to give every written form of any language an unambiguous identifier — and the rules for converting between forms.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm">
      <a href="/learn/introduction" class="inline-flex items-center gap-2 text-ink hover:text-gold-deep dark:hover:text-gold-bright">
        Start with the explainer
        <span aria-hidden="true">→</span>
      </a>
      <a href="/register" class="inline-flex items-center gap-2 text-ink-muted hover:text-gold-deep dark:hover:text-gold-bright">
        Browse the register
        <span aria-hidden="true">→</span>
      </a>
      <span class="text-ink-subtle">·</span>
      <span class="text-ink-subtle">
        Operated by <a href={externalLinks.calconnect}>CalConnect</a> as Registration Authority, designated by ISO.
      </span>
    </div>
  </section>

  {/* ── What problem does it solve ──────────────────────────── */}
  <section class="rule-section">
    <p class="eyebrow mb-3">Why it exists</p>
    <h2 class="max-w-3xl">
      A library catalogue in Tokyo, a gazetteer in Canberra, and a corpus
      in Berkeley might all reference the same Chinese romanization —
      each calling it something different.
    </h2>
    <p class="mt-6 text-ink-muted max-w-2xl leading-relaxed">
      ISO 24229 gives every system a single machine-readable code so data
      flows between library systems, geospatial databases, linguistic
      corpora, and software localisation pipelines without loss.
    </p>
  </section>

  {/* ── Code anatomy: SVG diagram ────────────────────────────── */}
  <section class="rule-section">
    <p class="eyebrow mb-3">What a code is made of</p>
    <h2 class="max-w-2xl mb-3">One code, four segments, three standards.</h2>
    <p class="text-ink-muted max-w-2xl mb-8 leading-relaxed">
      A single ISO 24229 code is built from identifiers you may already know:
      ISO 639 for languages, ISO 15924 for scripts. ISO 24229 is the standard
      that defines how they combine.
    </p>

    <div class="border border-rule rounded bg-paper-raised p-6 md:p-10">
      <svg viewBox="0 0 760 280" class="w-full h-auto" role="img" aria-label="Anatomy of the ISO 24229 code UN:ara-Arab:Latn:2017">
        <style>
          .code-seg { font-family: var(--font-mono, monospace); font-size: 28px; font-weight: 500; }
          .code-colon { fill: var(--color-ink-subtle, #888); font-family: var(--font-mono, monospace); font-size: 28px; }
          .lbl { font-family: var(--font-sans, sans-serif); font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; }
          .lbl-meta { font-family: var(--font-sans, sans-serif); font-size: 11px; }
          .arrow { stroke: var(--color-rule, #ccc); stroke-width: 1; fill: none; }
        </style>

        {/* The code itself, centered */}
        <text x="380" y="140" text-anchor="middle" class="code-seg" fill="var(--color-ink, #111)">
          <tspan fill="var(--color-gold-deep, #a86513)" class="code-seg">UN</tspan><tspan class="code-colon">:</tspan><tspan fill="var(--color-blue, #5374b9)" class="code-seg">ara-Arab</tspan><tspan class="code-colon">:</tspan><tspan fill="var(--color-blue, #5374b9)" class="code-seg">Latn</tspan><tspan class="code-colon">:</tspan><tspan fill="var(--color-ink, #111)" class="code-seg">2017</tspan>
        </text>

        {/* Bracket + label for UN (authority) */}
        <path d="M 220 156 L 220 168 L 270 168" class="arrow"/>
        <text x="245" y="190" text-anchor="middle" class="lbl" fill="var(--color-gold-deep, #a86513)">Authority</text>
        <text x="245" y="206" text-anchor="middle" class="lbl-meta" fill="var(--color-ink-muted, #666)">ISO 24229/AG</text>
        <text x="245" y="222" text-anchor="middle" class="lbl-meta" fill="var(--color-ink-subtle, #888)">United Nations</text>

        {/* Bracket + label for ara-Arab (source spelling) */}
        <path d="M 305 156 L 305 168 L 390 168" class="arrow"/>
        <text x="348" y="190" text-anchor="middle" class="lbl" fill="var(--color-blue, #5374b9)">Source spelling</text>
        <text x="348" y="206" text-anchor="middle" class="lbl-meta" fill="var(--color-ink-muted, #666)">ara — ISO 639</text>
        <text x="348" y="222" text-anchor="middle" class="lbl-meta" fill="var(--color-ink-subtle, #888)">Arab — ISO 15924</text>

        {/* Bracket + label for Latn (target spelling) */}
        <path d="M 460 156 L 460 168 L 530 168" class="arrow"/>
        <text x="495" y="190" text-anchor="middle" class="lbl" fill="var(--color-blue, #5374b9)">Target spelling</text>
        <text x="495" y="206" text-anchor="middle" class="lbl-meta" fill="var(--color-ink-muted, #666)">Latn — ISO 15924</text>
        <text x="495" y="222" text-anchor="middle" class="lbl-meta" fill="var(--color-ink-subtle, #888)">(script only)</text>

        {/* Bracket + label for 2017 (identifying) */}
        <path d="M 595 156 L 595 168 L 660 168" class="arrow"/>
        <text x="628" y="190" text-anchor="middle" class="lbl" fill="var(--color-ink-muted, #666)">Identifying</text>
        <text x="628" y="206" text-anchor="middle" class="lbl-meta" fill="var(--color-ink-subtle, #888)">Year of adoption</text>

        {/* Top label: standard */}
        <text x="380" y="50" text-anchor="middle" class="lbl" fill="var(--color-ink-subtle, #888)">ISO 24229 code</text>
        <line x1="220" y1="62" x2="540" y2="62" class="arrow"/>
      </svg>

      <p class="mt-6 text-sm text-ink-muted leading-relaxed max-w-2xl">
        United Nations romanization of Arabic, adopted 2017, is encoded
        as <span class="font-mono">UN:ara-Arab:Latn:2017</span>.
        Each segment carries independent, verifiable meaning.
      </p>
    </div>

    <p class="mt-5">
      <a href="/learn/code-structure" class="text-ink-muted hover:text-gold-deep dark:hover:text-gold-bright">
        Read the full code structure →
      </a>
    </p>
  </section>

  {/* ── Where to go next ─────────────────────────────────────── */}
  <section class="rule-section">
    <p class="eyebrow mb-3">Explore</p>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mt-6">
      <Card href="/learn" title="Learn" body="Codes, definitions, examples, and use cases." />
      <Card href="/register" title="Register content" body="Authorities, systems, and spelling systems." />
      <Card href="/news" title="News" body="Announcements from the RA and Advisory Group." />
      <Card href="/learn/learn/faq" title="FAQ" body="Common questions, briefly answered." />
    </div>
  </section>

  {/* ── For authorities and managers (small, below the fold) ── */}
  <section class="rule-section">
    <p class="eyebrow mb-3">For authorities & managers</p>
    <p class="text-ink-muted max-w-2xl">
      Already recognised as a conversion system authority, or sitting on
      the Advisory Group?
    </p>
    <div class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm">
      <a href="/about/apply" class="text-ink hover:text-gold-deep dark:hover:text-gold-bright">Apply / submit a system →</a>
      <a href="/about/managers" class="text-ink hover:text-gold-deep dark:hover:text-gold-bright">AG materials →</a>
      <a href="/specs" class="text-ink hover:text-gold-deep dark:hover:text-gold-bright">Specification (Annex A ToR) →</a>
    </div>
  </section>
</Layout>
