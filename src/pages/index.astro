---
import Layout from '../layouts/Layout.astro';
import SectionHead from '../components/SectionHead.astro';
import ArrowLink from '../components/ArrowLink.astro';
import Card from '../components/Card.astro';
import CodeTicker from '../components/CodeTicker.vue';
import { externalLinks } from '../config';
import { getCollection } from 'astro:content';
import codeNames from '../data/code-names.json';

// ── Select diverse real register codes for the ticker ──
const allSystems = await getCollection('system-code');
const allAuthorities = await getCollection('authority');
const authNames = new Map<string, string>();
for (const a of allAuthorities) {
  const id = String((a.data as Record<string, unknown>).authorityIdentifier ?? a.id);
  const name = String((a.data as Record<string, unknown>).name ?? a.id);
  authNames.set(id.toLowerCase(), name);
}

function lookupLang(code: string | undefined): string {
  if (!code) return '';
  return (codeNames as any).languages?.[code.toLowerCase()]?.name ?? code;
}
function lookupScript(code: string): string {
  return (codeNames as any).scripts?.[code]?.name ?? code;
}

interface TickerEntry {
  authority: string;
  source: string;
  target: string;
  identifying: string;
  authorityLabel: string;
  sourceLabel: string;
  targetLabel: string;
  identifyingLabel: string;
}

const seenAuth = new Set<string>();
const tickerCodes: TickerEntry[] = [];

for (const sys of allSystems) {
  const data = sys.data as Record<string, unknown>;
  const code = String(data.code ?? '');
  const segs = code.split(':');
  if (segs.length !== 4) continue;

  // Pick one per authority for diversity, skip "var" authority
  const authId = segs[0];
  if (authId === 'var' || authId === 'Var') continue;
  const authKey = authId.toLowerCase();
  if (seenAuth.has(authKey)) continue;
  seenAuth.add(authKey);

  // Parse the source spelling segment
  const sourceParts = segs[1].split('-');
  const sourceLang = sourceParts[0] && sourceParts[0].length <= 3 && sourceParts[0].match(/^[a-z]+$/) ? sourceParts[0] : '';
  const sourceScript = sourceParts.find((p) => p.length === 4 && p[0] === p[0].toUpperCase()) ?? '';
  const sourceCountry = sourceParts.find((p) => p.length === 2 && p === p.toUpperCase() && p.match(/^[A-Z]{2}$/)) ?? '';

  // Parse the target spelling segment
  const targetParts = segs[2].split('-');
  const targetLang = targetParts[0] && targetParts[0].length <= 3 && targetParts[0].match(/^[a-z]+$/) ? targetParts[0] : '';
  const targetScript = targetParts.find((p) => p.length === 4 && p[0] === p[0].toUpperCase()) ?? '';

  // Build labels
  const authName = authNames.get(authKey) ?? authId;
  const sourceLabel = [
    sourceLang ? lookupLang(sourceLang) : null,
    sourceScript ? lookupScript(sourceScript) : null,
    sourceCountry ? `(${sourceCountry})` : null,
  ].filter(Boolean).join(' · ') || sourceScript;

  const targetLabel = [
    targetLang ? lookupLang(targetLang) : null,
    targetScript ? lookupScript(targetScript) : null,
  ].filter(Boolean).join(' · ') || targetScript;

  // Identify what the identifying segment represents
  const ident = segs[3];
  let identifyingLabel: string;
  if (/^\d{4}$/.test(ident)) identifyingLabel = 'Year of adoption';
  else if (/^\d+-\d{4}$/.test(ident)) identifyingLabel = 'Standard no.';
  else if (/^v/i.test(ident)) identifyingLabel = 'Version';
  else identifyingLabel = 'Identifier';

  tickerCodes.push({
    authority: authId,
    source: segs[1],
    target: segs[2],
    identifying: ident,
    authorityLabel: authName,
    sourceLabel,
    targetLabel,
    identifyingLabel,
  });

  if (tickerCodes.length >= 10) break;
}
---

<Layout>
  {/* ── Hero ─────────────────────────────────────────────────── */}
  <section class="mb-20 pt-8 md:pt-16">
    <p class="eyebrow mb-5">
      <a href={externalLinks.iso24229Standard} class="hover:text-gold-deep dark:hover:text-gold-bright">ISO 24229</a>
      &nbsp;·&nbsp;International Standard
    </p>

    <h1 class="max-w-4xl">
      The international standard for
      <span class="text-ink-subtle"> writing system conversion codes</span>.
    </h1>

    <p class="mt-8 text-lg md:text-xl text-ink-muted max-w-2xl leading-relaxed">
      ISO 24229 gives every system that converts text from one script or
      spelling to another — transliteration, transcription, romanization,
      and orthographic reform alike — a single, unambiguous identifier.
    </p>

    <p class="mt-5 text-base text-ink-muted max-w-2xl leading-relaxed">
      ISO 24229 composes with <a href={externalLinks.iso639Standard}>ISO 639</a> (language) and <a href={externalLinks.iso15924Standard}>ISO 15924</a> (script) to give every written form of any language an unambiguous identifier — and the rules for converting between forms.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm">
      <a href="/learn/introduction" class="inline-flex items-center gap-2 text-ink hover:text-gold-deep dark:hover:text-gold-bright">
        Start with the explainer
        <span aria-hidden="true">→</span>
      </a>
      <a href="/register" class="inline-flex items-center gap-2 text-ink-muted hover:text-gold-deep dark:hover:text-gold-bright">
        Browse the register
        <span aria-hidden="true">→</span>
      </a>
      <span class="text-ink-subtle">·</span>
      <span class="text-ink-subtle">
        Operated by <a href={externalLinks.calconnect}>CalConnect</a> as Registration Authority, designated by ISO.
      </span>
    </div>
  </section>

  {/* ── What problem does it solve ──────────────────────────── */}
  <section class="rule-section">
    <p class="eyebrow mb-3">Why it exists</p>
    <h2 class="max-w-3xl">
      A library catalogue in Tokyo, a gazetteer in Canberra, and a corpus
      in Berkeley might all reference the same Chinese romanization —
      each calling it something different.
    </h2>
    <p class="mt-6 text-ink-muted max-w-2xl leading-relaxed">
      ISO 24229 gives every system a single machine-readable code so data
      flows between library systems, geospatial databases, linguistic
      corpora, and software localisation pipelines without loss.
    </p>
  </section>

  {/* ── Code anatomy: live ticker ─────────────────────────────── */}
  <section class="rule-section">
    <SectionHead eyebrow="What a code is made of" title="One code, four segments, three standards." titleClass="max-w-2xl mb-3" />
    <p class="text-ink-muted max-w-2xl mb-8 leading-relaxed">
      A single ISO 24229 code is built from identifiers you may already know:
      ISO 639 for languages, ISO 15924 for scripts. ISO 24229 is the standard
      that defines how they combine. Watch the ticker cycle through real codes.
    </p>

    <div class="border border-rule rounded bg-paper-raised p-6 md:p-10">
      <CodeTicker client:load codes={tickerCodes} />
    </div>

    <p class="mt-5">
      <ArrowLink href="/learn/code-structure">Read the full code structure</ArrowLink>
    </p>
  </section>

  {/* ── Where to go next ─────────────────────────────────────── */}
  <section class="rule-section">
    <p class="eyebrow mb-3">Explore</p>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mt-6">
      <Card href="/learn" title="Learn" body="Codes, definitions, examples, and use cases." />
      <Card href="/register" title="Register content" body="Authorities, systems, and spelling systems." />
      <Card href="/news" title="News" body="Announcements from the RA and Advisory Group." />
      <Card href="/learn/faq" title="FAQ" body="Common questions, briefly answered." />
    </div>
  </section>

  {/* ── For authorities and managers (small, below the fold) ── */}
  <section class="rule-section">
    <p class="eyebrow mb-3">For authorities & managers</p>
    <p class="text-ink-muted max-w-2xl">
      Already recognised as a conversion system authority, or sitting on
      the Advisory Group?
    </p>
    <div class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm">
      <ArrowLink href="/about/apply" variant="primary">Apply / submit a system</ArrowLink>
      <ArrowLink href="/about/managers" variant="primary">AG materials</ArrowLink>
      <ArrowLink href="/specs" variant="primary">Specification (Annex A ToR)</ArrowLink>
    </div>
  </section>
</Layout>
