---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths, InferGetStaticParamsType, InferGetStaticPropsType } from 'astro';

interface NewsFrontmatter {
  title: string;
  date: Date;
  summary: string;
  author?: string;
  tags: string[];
}

interface NewsEntry {
  id: string;
  data: NewsFrontmatter;
}

export const getStaticPaths = (async () => {
  const posts = (await getCollection('news')) as unknown as NewsEntry[];
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

type Params = InferGetStaticParamsType<typeof getStaticPaths>;

const { slug } = Astro.params as Params;
const { post } = Astro.props as { post: NewsEntry };

const all = ((await getCollection('news')) as unknown as NewsEntry[]).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const idx = all.findIndex((p) => p.id === slug);
const newer = idx > 0 ? all[idx - 1] : undefined;
const older = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : undefined;

function fmtDate(d: Date): string {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

function isoDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}

function fmtReadingTime(text: string): string {
  const words = text.trim().split(/\s+/).length;
  const minutes = Math.max(1, Math.round(words / 220));
  return `${minutes} min read`;
}

const fullEntry = (await getCollection('news')).find((p) => p.id === slug)!;
const { Content } = await render(fullEntry);
const body = (fullEntry as any).body ?? '';
const readingTime = fmtReadingTime(body);
---

<Layout title={post.data.title} description={post.data.summary}>
  <article>
    {/* ── Breadcrumb + back ─────────────────────────────────── */}
    <p class="text-sm text-ink-subtle mb-10">
      <a href="/news" class="hover:text-gold-deep dark:hover:text-gold-bright">← News</a>
    </p>

    {/* ── Article header ─────────────────────────────────────── */}
    <header class="mb-12 pb-10 border-b border-rule">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink-subtle mb-5 flex flex-wrap items-center gap-x-3 gap-y-1">
        <time datetime={isoDate(post.data.date)}>{fmtDate(post.data.date)}</time>
        <span aria-hidden="true" class="text-rule">·</span>
        <span>{readingTime}</span>
        {post.data.author && (
          <>
            <span aria-hidden="true" class="text-rule">·</span>
            <span>{post.data.author}</span>
          </>
        )}
      </p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-[3.25rem] font-bold tracking-[-0.035em] leading-[1.05] mb-6 max-w-4xl">
        {post.data.title}
      </h1>
      <p class="text-lg md:text-xl text-ink-muted leading-relaxed max-w-2xl">
        {post.data.summary}
      </p>
      {post.data.tags.length > 0 && (
        <ul class="mt-6 flex flex-wrap gap-x-4 gap-y-1 text-[0.7rem] font-mono uppercase tracking-[0.14em] text-ink-subtle">
          {post.data.tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )}
    </header>

    {/* ── Article body ───────────────────────────────────────── */}
    <div class="article max-w-2xl">
      <Content />
    </div>

    {/* ── Footer nav ─────────────────────────────────────────── */}
    {
      (newer || older) && (
        <nav class="mt-20 pt-8 border-t border-rule grid grid-cols-2 gap-8 text-sm">
          {newer ? (
            <a href={`/news/${newer.id}/`} class="group">
              <span class="block font-mono text-xs uppercase tracking-[0.14em] text-ink-subtle mb-1.5">Newer</span>
              <span class="block font-display font-semibold tracking-[-0.012em] text-ink group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors">
                {newer.data.title}
              </span>
            </a>
          ) : <span />}
          {older ? (
            <a href={`/news/${older.id}/`} class="group text-right">
              <span class="block font-mono text-xs uppercase tracking-[0.14em] text-ink-subtle mb-1.5">Older</span>
              <span class="block font-display font-semibold tracking-[-0.012em] text-ink group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors">
                {older.data.title}
              </span>
            </a>
          ) : <span />}
        </nav>
      )
    }
  </article>
</Layout>
