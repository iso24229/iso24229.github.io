---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

interface NewsFrontmatter {
  title: string;
  date: Date;
  summary: string;
  author?: string;
  tags: string[];
}

interface NewsEntry {
  id: string;
  data: NewsFrontmatter;
}

const posts = ((await getCollection('news')) as unknown as NewsEntry[])
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function fmtDate(d: Date): string {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout title="News">
  <h1 class="text-4xl font-semibold tracking-tight mb-2">News</h1>
  <p class="text-ink-muted max-w-2xl mb-10">
    Announcements from the ISO 24229 Registration Authority and Advisory
    Group.
  </p>

  {
    posts.length === 0 ? (
      <p class="text-ink-muted">No posts yet.</p>
    ) : (
      <ul class="space-y-8 max-w-3xl">
        {posts.map((post) => (
          <li class="border-t border-line pt-6">
            <p class="text-xs font-mono uppercase text-ink-subtle">
              {fmtDate(post.data.date)}
              {post.data.author && <span> · {post.data.author}</span>}
            </p>
            <h2 class="mt-1 text-2xl font-semibold tracking-tight">
              <a href={`/news/${post.id}/`} class="hover:text-accent">{post.data.title}</a>
            </h2>
            <p class="mt-2 text-ink-muted">{post.data.summary}</p>
            {post.data.tags.length > 0 && (
              <ul class="mt-3 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <li class="badge">{tag}</li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    )
  }
</Layout>
