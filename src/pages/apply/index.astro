---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { repoUrls, externalLinks } from '../../config';
---

<Layout title="Apply">
  <h1 class="text-4xl font-semibold tracking-tight mb-6">Apply</h1>

  <p class="text-lg text-ink-muted max-w-2xl mb-10">
    Two paths: an existing authority adding a new system to the register, or
    a new authority applying to register. Both start as a structured GitHub
    issue in the
    <a href={repoUrls.register} class="underline">register data repository</a>.
  </p>

  <div class="grid gap-4 md:grid-cols-2 mt-8">
    <Card
      href="/apply/existing-authority"
      title="Existing authority — new system"
      body="Add a new conversion system under your existing authority."
    />
    <Card
      href="/apply/new-authority"
      title="New authority — application"
      body="Apply to register a new authority with the Advisory Group."
    />
  </div>

  <p class="mt-12 text-ink-muted">
    Submissions follow a Unicode-style justification process. See
    <a href="/specification" class="underline">the specification</a>
    for the rules.
  </p>
</Layout>
