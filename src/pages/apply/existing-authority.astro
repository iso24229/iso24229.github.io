---
import Layout from '../../layouts/Layout.astro';
import { repoUrls } from '../../config';

const issueUrl = `${repoUrls.register}/issues/new?template=register-new-system.yml`;
---

<Layout title="Existing authority — new system">
  <p class="text-sm text-ink-subtle"><a href="/apply">← Apply</a></p>
  <h1 class="text-4xl font-semibold tracking-tight mb-6">New system — existing authority</h1>

  <p class="text-lg text-ink-muted max-w-2xl mb-8">
    Use this path if your organisation is already a registered authority and
    you want to add a new conversion system under it.
  </p>

  <h2 class="text-xl font-semibold mb-3">What you'll need</h2>
  <ul class="list-disc pl-6 space-y-2 mb-8">
    <li>The ISO 639 language code(s) for source and target languages.</li>
    <li>The ISO 15924 script code(s) for source and target scripts.</li>
    <li>A descriptive name and a short abstract of the system.</li>
    <li>A PDF or URL documenting the conversion rules.</li>
    <li>At least one URL demonstrating real-world use of the system.</li>
    <li>A justification (200+ words) following the Unicode-proposal pattern.</li>
  </ul>

  <a
    href={issueUrl}
    class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-surface rounded font-medium hover:bg-accent-dark transition-colors"
  >
    Open registration issue
    <span aria-hidden="true">→</span>
  </a>

  <p class="mt-6 text-sm text-ink-muted">
    The form validates your ISO 639 and ISO 15924 codes against our
    reference datasets
    (<a href={repoUrls.iso639Data} class="underline">iso639-data</a>, <a href={repoUrls.iso15924Data} class="underline">iso15924-data</a>)
    before submission.
  </p>
</Layout>
