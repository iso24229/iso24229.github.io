---
import Layout from '../../layouts/Layout.astro';
import { repoUrls } from '../../config';

const issueUrl = `${repoUrls.register}/issues/new?template=apply-new-authority.yml`;
---

<Layout title="New authority — application">
  <p class="text-sm text-ink-subtle"><a href="/apply">← Apply</a></p>
  <h1 class="text-4xl font-semibold tracking-tight mb-6">New authority — application</h1>

  <p class="text-lg text-ink-muted max-w-2xl mb-8">
    Authorities under ISO 24229 are recognised institutions that maintain
    one or more written-language conversion systems. Applications are
    reviewed by the <a href="/managers" class="underline">ISO/TC 46 Advisory Group</a>
    at its bimonthly meeting.
  </p>

  <h2 class="text-xl font-semibold mb-3">What you'll need</h2>
  <ul class="list-disc pl-6 space-y-2 mb-8">
    <li>Authority name, address, and contact details.</li>
    <li>Two named authorised persons (with their roles and contact emails).</li>
    <li>Evidence of competence — a recognised institutional track record in managing conversion systems.</li>
    <li>At least one conversion system that is eligible for a code.</li>
  </ul>

  <a
    href={issueUrl}
    class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-surface rounded font-medium hover:bg-accent-dark transition-colors"
  >
    Open authority application
    <span aria-hidden="true">→</span>
  </a>
</Layout>
