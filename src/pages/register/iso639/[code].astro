---
import Layout from '../../../layouts/Layout.astro';
import RegistrationBadge from '../../../components/RegistrationBadge.astro';
import { lookupLanguage } from '../../../domain/codes/CodeNames';
import { buildBrowsePaths, type EntryLike } from '../../../domain/browse/buildPaths';
import { externalLinks } from '../../../config';

export const getStaticPaths = buildBrowsePaths({ spellingField: 'languageCode' });

const ISO639_PARTS = {
  '639-1': {
    name: 'Part 1: Alpha-2 code',
    desc: 'Two-letter codes for major languages (the ~180 most-referenced).',
    raUrl: externalLinks.iso639_1RA,
    raName: 'Library of Congress (ISO 639-1/2 RA)',
    stdUrl: externalLinks.iso639_1Standard,
  },
  '639-2': {
    name: 'Part 2: Alpha-3 code',
    desc: 'Three-letter codes for ~500 languages; each may have separate bibliographic (B) and terminological (T) forms.',
    raUrl: externalLinks.iso639_2RA,
    raName: 'Library of Congress',
    stdUrl: externalLinks.iso639_2Standard,
  },
  '639-3': {
    name: 'Part 3: Alpha-3 code (comprehensive)',
    desc: 'Three-letter codes for all ~7 900 individual living, extinct, ancient, and historic languages — the most comprehensive part.',
    raUrl: externalLinks.iso639_3RA,
    raName: 'SIL International',
    stdUrl: externalLinks.iso639_3Standard,
  },
  '639-5': {
    name: 'Part 5: Alpha-3 code for families',
    desc: 'Three-letter codes for language families and groups (~115 collective codes).',
    raUrl: externalLinks.iso639_5RA,
    raName: 'Library of Congress (ISO 639-5 RA)',
    stdUrl: externalLinks.iso639_5Standard,
  },
} as const;

const { code, asSource, asTarget } = Astro.props as {
  code: string;
  asSource: EntryLike[];
  asTarget: EntryLike[];
};
const total = asSource.length + asTarget.length;
const info = lookupLanguage(code);
const partInfo = info ? ISO639_PARTS[info.part as keyof typeof ISO639_PARTS] : null;
---

<Layout title={`Systems for language ${code}`}>
  <p class="text-sm text-ink-subtle mb-2">
    <a href="/register">← Register</a>
  </p>
  <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink-subtle mb-3">ISO 639 · language code</p>
  <h1 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold tracking-[-0.035em] leading-[1.05] mb-3">
    {info ? info.name : code}
  </h1>
  <p class="font-mono text-base md:text-lg text-ink-muted mb-2">
    <span class="text-ink-subtle">code:</span>
    <span class="text-blue dark:text-blue-bright">{code}</span>
    {info && <span class="ml-2 text-ink-subtle">· {info.part}</span>}
  </p>

  {info && partInfo && (
    <div class="max-w-2xl mb-2">
      <p class="mt-2 text-sm text-ink-muted leading-relaxed">
        Defined by <a href={info.url} target="_blank" rel="noopener" class="text-blue dark:text-blue-bright underline">ISO 639 ({info.part}) <span aria-hidden="true">↗</span></a> — {partInfo.desc}
      </p>
      <p class="mt-1 text-xs text-ink-subtle">
        Registration Authority: <a href={partInfo.raUrl} target="_blank" rel="noopener" class="text-blue dark:text-blue-bright underline">{partInfo.raName}</a>
        · Standard: <a href={partInfo.stdUrl} target="_blank" rel="noopener" class="text-blue dark:text-blue-bright underline">ISO {info.part} on iso.org ↗</a>
      </p>
    </div>
  )}

  <div class="mt-6 max-w-2xl border-l-2 border-blue/40 dark:border-blue-bright/40 pl-4 py-2">
    <p class="text-sm text-ink-muted leading-relaxed">
      <strong class="text-ink">Reference data.</strong> ISO 639 is maintained by ISO through separate Language Coding Agencies for each part: Library of Congress for ISO 639-1/2/5, SIL International for ISO 639-3. This register is <strong>not</strong> the authoritative source for ISO 639 codes — it indexes them so that systems in the ISO 24229 register can reference stable identifiers. For canonical definitions, follow the links above.
    </p>
    <p class="text-xs mt-2">
      <a href="/about#reference-standards" class="text-blue dark:text-blue-bright underline">All ISO 639 parts and their authorities →</a>
    </p>
  </div>

  <p class="text-ink-muted max-w-2xl mt-6 mb-2 leading-relaxed">
    Every system in the register whose source or target spelling system uses this ISO 639 language code.
  </p>
  <p class="text-sm text-ink-muted mb-10">
    {total} system{total === 1 ? '' : 's'} · {asSource.length} as source · {asTarget.length} as target
  </p>

  {total === 0 ? (
    <p class="text-ink-muted">No systems reference this language code.</p>
  ) : (
    <div class="space-y-12">
      {asSource.length > 0 && (
        <section>
          <p class="eyebrow mb-3">As source language ({asSource.length})</p>
          <ul class="divide-y divide-rule border-y border-rule">
            {asSource.map((entry) => (
              <li>
                <a href={`/register/system-code/i/${entry.id}`} class="grid grid-cols-[1fr_auto_auto] items-baseline gap-x-4 sm:gap-x-6 py-3 group">
                  <span class="font-mono text-sm md:text-base text-ink group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors truncate">{String(entry.data.code ?? entry.id)}</span>
                  <span class="hidden sm:block text-ink-muted text-sm truncate text-right max-w-[24rem]">{String(entry.data.name ?? '')}</span>
                  <span class="justify-self-end"><RegistrationBadge status={entry.data.registrationStatus} /></span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
      {asTarget.length > 0 && (
        <section>
          <p class="eyebrow mb-3">As target language ({asTarget.length})</p>
          <ul class="divide-y divide-rule border-y border-rule">
            {asTarget.map((entry) => (
              <li>
                <a href={`/register/system-code/i/${entry.id}`} class="grid grid-cols-[1fr_auto_auto] items-baseline gap-x-4 sm:gap-x-6 py-3 group">
                  <span class="font-mono text-sm md:text-base text-ink group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors truncate">{String(entry.data.code ?? entry.id)}</span>
                  <span class="hidden sm:block text-ink-muted text-sm truncate text-right max-w-[24rem]">{String(entry.data.name ?? '')}</span>
                  <span class="justify-self-end"><RegistrationBadge status={entry.data.registrationStatus} /></span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  )}
</Layout>
