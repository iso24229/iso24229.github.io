---
import Layout from '../../../layouts/Layout.astro';
import RegistrationBadge from '../../../components/RegistrationBadge.astro';
import { getCollection } from 'astro:content';
import { JsonLdExporter } from '../../../semantic/JsonLdExporter';
import { itemFactories } from '../../../domain/factories';
import { Authority } from '../../../domain/items/Authority';
import {
  REGISTRATION_STATUS_ORDER,
  isRegistrationStatus,
  type RegistrationStatus,
} from '../../../domain/registration/RegistrationStatus';
import type { GetStaticPaths, InferGetStaticParamsType } from 'astro';

type RawEntry = { id: string; data: unknown };

function refId(v: unknown): string | null {
  if (v == null) return null;
  if (typeof v === 'string') return v;
  if (typeof v === 'object') {
    const obj = v as Record<string, unknown>;
    const direct = obj.id ?? obj.uuid ?? obj.$ref ?? obj.slug;
    if (typeof direct === 'string') return direct;
  }
  return null;
}

export const getStaticPaths = (async () => {
  const coll = (await getCollection('authority')) as unknown as RawEntry[];
  return coll.map((entry) => ({
    params: { uuid: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { uuid } = Astro.params as InferGetStaticParamsType<typeof getStaticPaths>;
const { entry } = Astro.props as { entry: RawEntry };

const authority = itemFactories.authority(entry.data as Record<string, unknown>) as Authority;

// All systems for this authority (Zod references are objects — use refId + case-insensitive)
const allSystemsRaw = (await getCollection('system-code')) as unknown as RawEntry[];
const systemsForAuthority = allSystemsRaw
  .filter((s) => {
    const id = refId((s.data as Record<string, unknown>).authority);
    return id !== null && id.toLowerCase() === uuid!.toLowerCase();
  })
  .map((s) => ({
    id: s.id,
    data: s.data as Record<string, unknown>,
  }));

// Status breakdown
const statusCounts = new Map<RegistrationStatus, number>();
for (const s of systemsForAuthority) {
  const v = s.data.registrationStatus;
  if (isRegistrationStatus(v)) statusCounts.set(v, (statusCounts.get(v) ?? 0) + 1);
}
const statusBreakdown = REGISTRATION_STATUS_ORDER
  .map((status) => ({ status, count: statusCounts.get(status) ?? 0 }))
  .filter((x) => x.count > 0);

const jsonLd = new JsonLdExporter().exportItem(authority);
const data = entry.data as Record<string, unknown>;
const address = (data.address ?? null) as { street: string; city: string; country: string; postalCode: string } | null;
const contact = (data.contact ?? null) as { email?: string; url?: string } | null;
const persons = (data.authorisedPersons ?? []) as Array<{ name: string; role: string; email: string }>;
---

<Layout title={authority.displayName}>
  <p class="text-sm text-ink-subtle mb-2">
    <a href="/register/authority">Authorities</a> →
  </p>
  <div class="flex flex-wrap items-center gap-2 mb-3">
    <RegistrationBadge status={data.registrationStatus} />
    <span class="badge">authority</span>
  </div>
  <h1 class="text-4xl font-semibold tracking-tight mb-2">{authority.displayName}</h1>
  <p class="font-mono text-ink-subtle mb-6">@{authority.authorityIdentifier}</p>
  {data.abstract && (
    <p class="text-base md:text-lg text-ink leading-relaxed max-w-3xl mb-6">{String(data.abstract)}</p>
  )}
  {data.uri && (
    <p class="font-mono text-sm text-ink-muted break-all mb-6">
      <span class="text-ink-subtle">URI:</span>
      <span class="ml-2">{String(data.uri)}</span>
    </p>
  )}

  <div class="grid gap-8 md:grid-cols-2 max-w-4xl mb-12">
    <section>
      <h2 class="text-sm font-mono uppercase text-ink-subtle mb-3">Address</h2>
      {
        address ? (
          <address class="not-italic text-sm leading-relaxed">
            {address.street}<br />
            {address.city}<br />
            {address.country} {address.postalCode}
          </address>
        ) : (
          <p class="text-sm text-ink-muted">Not provided.</p>
        )
      }
    </section>

    <section>
      <h2 class="text-sm font-mono uppercase text-ink-subtle mb-3">Contact</h2>
      <ul class="text-sm space-y-1">
        {contact?.email && <li><a href={`mailto:${contact.email}`} class="underline">{contact.email}</a></li>}
        {contact?.url && <li><a href={contact.url} target="_blank" rel="noopener" class="underline">{contact.url}</a></li>}
        {!contact?.email && !contact?.url && <li class="text-ink-muted">Not provided.</li>}
      </ul>
    </section>

    <section class="md:col-span-2">
      <h2 class="text-sm font-mono uppercase text-ink-subtle mb-3">Authorised persons</h2>
      {
        persons.length === 2 ? (
          <ul class="grid gap-4 md:grid-cols-2">
            {persons.map((p) => (
              <li class="border border-rule rounded p-4">
                <p class="font-medium">{p.name}</p>
                <p class="text-sm text-ink-muted">{p.role}</p>
                <p class="text-sm mt-2"><a href={`mailto:${p.email}`} class="underline">{p.email}</a></p>
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-sm text-ink-muted">
            Two authorised persons not yet on file. Per Annex A.4, this must be remedied before this authority can submit changes.
          </p>
        )
      }
    </section>
  </div>

  {/* ── Systems registered under this authority ─────────────────── */}
  <section class="rule-section">
    <div class="flex items-baseline justify-between gap-4 mb-4">
      <h2 class="text-2xl font-semibold tracking-tight">Systems registered</h2>
      <p class="text-sm text-ink-muted">{systemsForAuthority.length} system{systemsForAuthority.length === 1 ? '' : 's'}</p>
    </div>

    {statusBreakdown.length > 0 && (
      <div class="mb-6 flex flex-wrap gap-x-3 gap-y-2 items-center">
        <span class="eyebrow">Status:</span>
        <ul class="flex flex-wrap gap-x-3 gap-y-1.5">
          {statusBreakdown.map(({ status, count }) => (
            <li class="flex items-center gap-1.5 text-sm">
              <RegistrationBadge status={status} />
              <span class="font-mono text-ink-subtle">{count}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {
      systemsForAuthority.length === 0 ? (
        <p class="text-ink-muted">No systems registered yet.</p>
      ) : (
        <ul class="divide-y divide-rule border-y border-rule">
          {systemsForAuthority.map((s) => (
            <li>
              <a
                href={`/register/system-code/i/${s.id}`}
                class="grid grid-cols-[1fr_auto] sm:grid-cols-[1fr_auto_auto] items-baseline gap-x-4 sm:gap-x-6 py-3 group"
              >
                <span class="font-mono text-sm md:text-base text-ink group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors truncate">
                  {String(s.data.code ?? s.id)}
                </span>
                <span class="hidden sm:block text-ink-muted text-sm truncate text-right max-w-[24rem]">
                  {String(s.data.name ?? '')}
                </span>
                <span class="justify-self-end">
                  <RegistrationBadge status={s.data.registrationStatus} />
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <script type="application/ld+json" set:html={jsonLd} />
</Layout>
