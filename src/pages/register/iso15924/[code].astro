---
import Layout from '../../../layouts/Layout.astro';
import RegistrationBadge from '../../../components/RegistrationBadge.astro';
import { getCollection } from 'astro:content';
import { lookupScript } from '../../../domain/codes/CodeNames';
import type { GetStaticPaths } from 'astro';

interface EntryLike { id: string; data: Record<string, unknown>; }

export const getStaticPaths = (async () => {
  function refId(v: unknown): string | null {
    if (v == null) return null;
    if (typeof v === 'string') return v;
    if (typeof v === 'object') {
      const obj = v as Record<string, unknown>;
      const direct = obj.id ?? obj.uuid ?? obj.$ref ?? obj.slug;
      if (typeof direct === 'string') return direct;
    }
    return null;
  }

  const all = (await getCollection('system-code')) as unknown as EntryLike[];
  const allSpellings = (await getCollection('spelling-system')) as unknown as EntryLike[];

  const scriptOf = new Map<string, string>();
  for (const s of allSpellings) {
    const sc = s.data.scriptCode;
    if (typeof sc === 'string' && sc.length > 0) {
      scriptOf.set(s.id.toLowerCase(), sc);
    }
  }

  function scriptsFor(entry: EntryLike): { source?: string; target?: string } {
    let source: string | undefined;
    let target: string | undefined;
    const sourceSpellingId = refId(entry.data.sourceSpelling);
    const targetSpellingId = refId(entry.data.targetSpelling);
    if (sourceSpellingId) {
      const key = sourceSpellingId.toLowerCase();
      if (scriptOf.has(key)) source = scriptOf.get(key);
    }
    if (targetSpellingId) {
      const key = targetSpellingId.toLowerCase();
      if (scriptOf.has(key)) target = scriptOf.get(key);
    }
    if (!source && typeof entry.data.sourceScriptCode === 'string' && entry.data.sourceScriptCode.length > 0) source = entry.data.sourceScriptCode;
    if (!target && typeof entry.data.targetScriptCode === 'string' && entry.data.targetScriptCode.length > 0) target = entry.data.targetScriptCode;
    return { source, target };
  }

  const byScript = new Map<string, { asSource: EntryLike[]; asTarget: EntryLike[] }>();
  for (const e of all) {
    const { source, target } = scriptsFor(e);
    if (source) {
      if (!byScript.has(source)) byScript.set(source, { asSource: [], asTarget: [] });
      byScript.get(source)!.asSource.push(e);
    }
    if (target) {
      if (!byScript.has(target)) byScript.set(target, { asSource: [], asTarget: [] });
      byScript.get(target)!.asTarget.push(e);
    }
  }

  return [...byScript.keys()].sort().map((code) => ({
    params: { code },
    props: {
      code,
      asSource: byScript.get(code)!.asSource,
      asTarget: byScript.get(code)!.asTarget,
    },
  }));
}) satisfies GetStaticPaths;

const { code, asSource, asTarget } = Astro.props as {
  code: string;
  asSource: EntryLike[];
  asTarget: EntryLike[];
};
const total = asSource.length + asTarget.length;
const info = lookupScript(code);
---

<Layout title={`Systems for script ${code}`}>
  <p class="text-sm text-ink-subtle mb-2">
    <a href="/register">← Register</a>
  </p>
  <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink-subtle mb-3">ISO 15924</p>
  <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-3">
    Script <span class="font-mono text-blue dark:text-blue-bright">{code}</span>
  </h1>

  {info && (
    <div class="max-w-2xl mb-2">
      <p class="text-xl text-ink font-display font-semibold tracking-[-0.018em]">{info.name}</p>
      <p class="mt-2 text-sm text-ink-muted leading-relaxed">
        Defined by <a href={info.url} target="_blank" rel="noopener" class="text-blue dark:text-blue-bright underline">ISO 15924 at the Unicode Consortium <span aria-hidden="true">↗</span></a>.
      </p>
    </div>
  )}

  <p class="text-ink-muted max-w-2xl mt-6 mb-2 leading-relaxed">
    Every system in the register whose source or target uses this ISO 15924 script code.
  </p>
  <p class="text-sm text-ink-muted mb-10">
    {total} system{total === 1 ? '' : 's'} · {asSource.length} as source · {asTarget.length} as target
  </p>

  {total === 0 ? (
    <p class="text-ink-muted">No systems reference this script code.</p>
  ) : (
    <div class="space-y-12">
      {asSource.length > 0 && (
        <section>
          <p class="eyebrow mb-3">As source script ({asSource.length})</p>
          <ul class="divide-y divide-rule border-y border-rule">
            {asSource.map((entry) => (
              <li>
                <a href={`/register/system-code/i/${entry.id}`} class="grid grid-cols-[1fr_auto_auto] items-baseline gap-x-4 sm:gap-x-6 py-3 group">
                  <span class="font-mono text-sm md:text-base text-ink group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors truncate">{String(entry.data.code ?? entry.id)}</span>
                  <span class="hidden sm:block text-ink-muted text-sm truncate text-right max-w-[24rem]">{String(entry.data.name ?? '')}</span>
                  <span class="justify-self-end"><RegistrationBadge status={entry.data.registrationStatus} /></span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
      {asTarget.length > 0 && (
        <section>
          <p class="eyebrow mb-3">As target script ({asTarget.length})</p>
          <ul class="divide-y divide-rule border-y border-rule">
            {asTarget.map((entry) => (
              <li>
                <a href={`/register/system-code/i/${entry.id}`} class="grid grid-cols-[1fr_auto_auto] items-baseline gap-x-4 sm:gap-x-6 py-3 group">
                  <span class="font-mono text-sm md:text-base text-ink group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors truncate">{String(entry.data.code ?? entry.id)}</span>
                  <span class="hidden sm:block text-ink-muted text-sm truncate text-right max-w-[24rem]">{String(entry.data.name ?? '')}</span>
                  <span class="justify-self-end"><RegistrationBadge status={entry.data.registrationStatus} /></span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  )}
</Layout>
