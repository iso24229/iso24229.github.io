---
import Layout from '../../../../layouts/Layout.astro';
import LifecycleGraph from '../../../../components/LifecycleGraph.astro';
import RegistrationBadge from '../../../../components/RegistrationBadge.astro';
import CodeChip from '../../../../components/CodeChip.astro';
import { getCollection } from 'astro:content';
import type { ItemClassSlug } from '../../../../domain/items/RegisterItem';
import type { SystemCode } from '../../../../domain/items/SystemCode';
import { RegisterIndex } from '../../../../domain/register/RegisterIndex';
import { buildLifecycleGraph } from '../../../../domain/graph/buildLifecycleGraph';
import { itemClassSlugs } from '../../../../domain/registry/ItemClassRegistry';
import { schemaWithRichData, mapSchema, primitiveTypeOf, titleOf } from '../../../../content.config';
import { externalLinks, repoUrls } from '../../../../config';
import type { GetStaticPaths, InferGetStaticParamsType, InferGetStaticPropsType } from 'astro';

interface EntryLike { id: string; data: Record<string, unknown>; }
interface Example { input: string; output: string; remarks?: string | null }

export const getStaticPaths = (async () => {
  const all = await Promise.all(
    itemClassSlugs.map(async (itemClass) => {
      const collection = await getCollection(itemClass);
      return {
        itemClass,
        entries: collection.map((c) => ({ id: c.id, data: c.data as Record<string, unknown> })),
      };
    }),
  );
  return all.flatMap(({ itemClass, entries }) =>
    (entries as EntryLike[]).map((entry) => ({
      params: { itemClass, uuid: entry.id },
      props: { entry },
    })),
  );
}) satisfies GetStaticPaths;

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { itemClass, uuid } = Astro.params as Params;
const { entry } = Astro.props as Props;

const classTitle = schemaWithRichData[itemClass as ItemClassSlug].title;
const schema = schemaWithRichData[itemClass as ItemClassSlug].schema;
const fields = mapSchema(schema, ([k, t]) => ({ key: k, title: titleOf(k, t), type: primitiveTypeOf(t) }));

const isSystemCode = itemClass === 'system-code';
const isAuthority = itemClass === 'authority';
const isSpellingSystem = itemClass === 'spelling-system';

// Helpers --------------------------------------------------------------
function refId(v: unknown): string | null {
  if (v == null) return null;
  if (typeof v === 'string') return v;
  if (typeof v === 'object') {
    const obj = v as Record<string, unknown>;
    const direct = obj.id ?? obj.uuid ?? obj.$ref ?? obj.slug;
    if (typeof direct === 'string') return direct;
    if (obj.data && typeof obj.data === 'object') {
      const inner = (obj.data as Record<string, unknown>);
      const id = inner.id ?? inner.uuid ?? inner.$ref;
      if (typeof id === 'string') return id;
    }
  }
  return null;
}

function refIds(v: unknown): string[] {
  if (v == null) return [];
  if (Array.isArray(v)) {
    return v.map(refId).filter((x): x is string => x !== null);
  }
  const single = refId(v);
  return single ? [single] : [];
}

function titleCaseLabel(s: string): string {
  return s
    .replace(/([a-z00-9])([A-Z])/g, '$1 $2')
    .replace(/[_-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

function fieldLabel(key: string): string {
  const f = fields.find((x) => x.key === key);
  const raw = f?.title && f.title.length > 0 ? f.title : key;
  return /\s/.test(raw) ? raw : titleCaseLabel(raw);
}

function fieldValue(key: string): string {
  const v = entry.data[key];
  const id = refId(v);
  if (id !== null) return id;
  if (v === null || v === undefined || v === '') return '—';
  if (Array.isArray(v)) {
    if (v.length === 0) return '—';
    const parts = v.map((item) => refId(item) ?? (typeof item === 'string' ? item : JSON.stringify(item)));
    return parts.join(', ');
  }
  if (v instanceof Date) {
    return v.toISOString().replace(/\.\d{3}Z$/, 'Z');
  }
  return String(v);
}

// System-code rendering -----------------------------------------------
let codeSegments: readonly [string, string, string, string] | null = null;
let authorityEntry: EntryLike | null = null;
let sourceSpellingEntry: EntryLike | null = null;
let targetSpellingEntry: EntryLike | null = null;
let graphNodes: any[] = [];
let graphEdges: any[] = [];
let relations: Array<{ uuid: string; type: string; targetSystem: string; targetName: string }> = [];
let sourceLanguage = '';
let sourceScript = '';
let targetLanguage = '';
let targetScript = '';
let allSystemsForCrossLink: EntryLike[] = [];

if (isSystemCode) {
  const code = String(entry.data.code ?? '');
  const segs = code.split(':');
  if (segs.length === 4) codeSegments = segs as [string, string, string, string];

  type RawEntry = { id: string; data: unknown };
  const index = await RegisterIndex.load(async (slug) => {
    const coll = (await getCollection(slug as Parameters<typeof getCollection>[0])) as unknown as RawEntry[];
    return coll.map((c) => ({ id: c.id, data: c.data as Record<string, unknown> }));
  });

  const sc = index.byUuid<SystemCode>('system-code', uuid!);

  // Authority
  const authorityId = refId(entry.data.authority);
  if (authorityId) {
    const all = (await getCollection('authority')) as unknown as RawEntry[];
    authorityEntry = all
      .filter((a) => a.id === authorityId)
      .map((a) => ({ id: a.id, data: a.data as Record<string, unknown> }))[0] ?? null;
  }

  // Source spelling
  const sourceSpellingId = refId(entry.data.sourceSpelling);
  if (sourceSpellingId) {
    const all = (await getCollection('spelling-system')) as unknown as RawEntry[];
    sourceSpellingEntry = all
      .filter((s) => s.id.toLowerCase() === sourceSpellingId.toLowerCase())
      .map((s) => ({ id: s.id, data: s.data as Record<string, unknown> }))[0] ?? null;
    if (sourceSpellingEntry) {
      sourceLanguage = String(sourceSpellingEntry.data.languageCode ?? '');
      sourceScript = String(sourceSpellingEntry.data.scriptCode ?? '');
    }
  } else if (entry.data.sourceScriptCode) {
    sourceScript = String(entry.data.sourceScriptCode);
  }

  // Target spelling
  const targetSpellingId = refId(entry.data.targetSpelling);
  if (targetSpellingId) {
    const all = (await getCollection('spelling-system')) as unknown as RawEntry[];
    targetSpellingEntry = all
      .filter((s) => s.id.toLowerCase() === targetSpellingId.toLowerCase())
      .map((s) => ({ id: s.id, data: s.data as Record<string, unknown> }))[0] ?? null;
    if (targetSpellingEntry) {
      targetLanguage = String(targetSpellingEntry.data.languageCode ?? '');
      targetScript = String(targetSpellingEntry.data.scriptCode ?? '');
    }
  } else if (entry.data.targetScriptCode) {
    targetScript = String(entry.data.targetScriptCode);
  }

  // Relations: load each referenced system-relation + its target system
  const relationIds = refIds(entry.data.relations);
  if (relationIds.length > 0) {
    const allRelations = (await getCollection('system-relation')) as unknown as RawEntry[];
    const allSystems = (await getCollection('system-code')) as unknown as RawEntry[];
    allSystemsForCrossLink = allSystems.map((s) => ({ id: s.id, data: s.data as Record<string, unknown> }));
    for (const rid of relationIds) {
      const rel = allRelations.find((r) => r.id === rid);
      if (!rel) continue;
      const relData = rel.data as Record<string, unknown>;
      const targetSysId = refId(relData.targetSystem) ?? '';
      const target = allSystems.find((s) => s.id === targetSysId);
      relations.push({
        uuid: rel.id,
        type: String(relData.type ?? ''),
        targetSystem: targetSysId,
        targetName: target ? String((target.data as Record<string, unknown>).name ?? targetSysId) : targetSysId,
      });
    }
  }

  // Lifecycle graph
  if (sc) {
    const g = buildLifecycleGraph(index, sc);
    graphNodes = g.nodes;
    graphEdges = g.edges;
  }
}

// Spelling-system: find systems using this as source or target
let sourceOfSystems: EntryLike[] = [];
let targetOfSystems: EntryLike[] = [];
if (isSpellingSystem) {
  const allSystems = (await getCollection('system-code')) as unknown as { id: string; data: unknown }[];
  const list = allSystems.map((s) => ({ id: s.id, data: s.data as Record<string, unknown> }));
  const uuidLower = (uuid ?? '').toLowerCase();
  sourceOfSystems = list.filter((s) => (refId(s.data.sourceSpelling) ?? '').toLowerCase() === uuidLower);
  targetOfSystems = list.filter((s) => (refId(s.data.targetSpelling) ?? '').toLowerCase() === uuidLower);
}

const examplesRaw = entry.data.examples;
const examples: Example[] = Array.isArray(examplesRaw)
  ? examplesRaw
      .filter((e): e is Record<string, unknown> => typeof e === 'object' && e !== null)
      .map((e) => ({
        input: String(e.input ?? ''),
        output: String(e.output ?? ''),
        remarks: typeof e.remarks === 'string' ? e.remarks : null,
      }))
      .filter((e) => e.input && e.output)
  : [];

const specificationRaw = entry.data.specification;
const specificationUrls: string[] = Array.isArray(specificationRaw)
  ? specificationRaw.filter((u): u is string => typeof u === 'string' && u.length > 0)
  : [];

interface ReferenceEntry {
  id: string;
  label: string;
  title: string;
  publisher?: string | null;
  date?: string | null;
  url?: string | null;
}
const referencesRaw = entry.data.references;
const references: ReferenceEntry[] = Array.isArray(referencesRaw)
  ? referencesRaw
      .filter((r): r is Record<string, unknown> => typeof r === 'object' && r !== null)
      .map((r) => {
        const id = String(r.id ?? '');
        const label = String(r.label ?? r.citation ?? id);
        const title = String(r.title ?? r.citation ?? label);
        return {
          id,
          label,
          title,
          publisher: typeof r.publisher === 'string' ? r.publisher : null,
          date: typeof r.date === 'string' ? r.date : null,
          url: typeof r.url === 'string' ? r.url : null,
        };
      })
      .filter((r) => r.id && r.label && r.title)
  : [];

const notesRaw = entry.data.notes;
const notes: string[] = Array.isArray(notesRaw)
  ? notesRaw.filter((n): n is string => typeof n === 'string' && n.length > 0)
  : [];

const provenanceRaw = entry.data.provenance;
const provenance: string[] = Array.isArray(provenanceRaw)
  ? provenanceRaw.filter((n): n is string => typeof n === 'string' && n.length > 0)
  : [];

const codeStatusId = refId(entry.data.codeStatus) ?? '';
const systemStatusId = refId(entry.data.systemStatus) ?? '';
const uri = typeof entry.data.uri === 'string' ? entry.data.uri : '';
const abstractText = typeof entry.data.abstract === 'string' ? entry.data.abstract : '';
---

<Layout title={`${classTitle} — ${uuid}`}>
  <p class="text-sm text-ink-subtle mb-6">
    <a href={`/register/${itemClass}`} class="hover:text-ink">{classTitle}</a>
    <span class="mx-2">/</span>
    <span class="font-mono">{uuid}</span>
  </p>

  {/* ── System-code: hero with full code + segments ───────────── */}
  {isSystemCode && codeSegments && (
    <section class="mb-12">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <RegistrationBadge status={entry.data.registrationStatus} />
        {codeStatusId && <span class="badge">code: {codeStatusId}</span>}
        {systemStatusId && <span class="badge">system: {systemStatusId}</span>}
      </div>

      <p class="font-mono text-2xl md:text-4xl lg:text-5xl break-all leading-tight mb-4">
        <a href={`/register/authority/${codeSegments[0].toLowerCase()}`} class="text-gold-deep dark:text-gold-bright hover:underline">{codeSegments[0]}</a><span class="text-ink-subtle">:</span><span class="text-blue dark:text-blue-bright">{codeSegments[1]}</span><span class="text-ink-subtle">:</span><span class="text-blue dark:text-blue-bright">{codeSegments[2]}</span><span class="text-ink-subtle">:</span><span class="text-ink">{codeSegments[3]}</span>
      </p>

      <h1 class="text-2xl md:text-3xl font-semibold tracking-tight mb-4">{String(entry.data.name ?? uuid)}</h1>

      {abstractText && (
        <p class="text-lg md:text-xl text-ink leading-relaxed max-w-3xl mb-4">{abstractText}</p>
      )}

      {entry.data.description && (
        <p class="text-base text-ink-muted max-w-3xl leading-relaxed mb-4">{String(entry.data.description)}</p>
      )}

      {uri && (
        <p class="font-mono text-sm text-ink-muted max-w-3xl break-all mb-4">
          <span class="text-ink-subtle">URI:</span>
          <span class="ml-2">{uri}</span>
        </p>
      )}

      {entry.data.remarks && (
        <p class="mt-4 text-sm text-ink-subtle italic max-w-3xl">{String(entry.data.remarks)}</p>
      )}
    </section>
  )}

  {/* ── Non-system-code: standard hero ────────────────────────── */}
  {!isSystemCode && (
    <section class="mb-10">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <RegistrationBadge status={entry.data.registrationStatus} />
        {isAuthority && <span class="badge">authority</span>}
      </div>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-2">{String(entry.data.name ?? entry.data.code ?? uuid)}</h1>
      {!isAuthority && (
        <p class="font-mono text-sm text-ink-subtle">{uuid}</p>
      )}
      {entry.data.abstract && (
        <p class="mt-4 text-base md:text-lg text-ink leading-relaxed max-w-3xl">{String(entry.data.abstract)}</p>
      )}
      {entry.data.uri && (
        <p class="mt-3 font-mono text-sm text-ink-muted break-all">
          <span class="text-ink-subtle">URI:</span>
          <span class="ml-2">{String(entry.data.uri)}</span>
        </p>
      )}
      {entry.data.remarks && (
        <p class="mt-4 text-base text-ink-muted max-w-2xl leading-relaxed">{String(entry.data.remarks)}</p>
      )}
    </section>
  )}

  {/* ── Lifecycle graph (system-code only) ───────────────────── */}
  {isSystemCode && graphNodes.length > 0 && (
    <section class="mb-12">
      <LifecycleGraph nodes={graphNodes} edges={graphEdges} />
    </section>
  )}

  <div class="grid gap-12 lg:grid-cols-[1fr_280px]">
    {/* ── Main column ─────────────────────────────────────────── */}
    <div class="max-w-3xl space-y-12">

      {/* Authority cross-link */}
      {isSystemCode && authorityEntry && (
        <section>
          <p class="eyebrow mb-3">Maintained by</p>
          <a href={`/register/authority/${authorityEntry.id}`} class="card-link block">
            <p class="text-base font-semibold">{String(authorityEntry.data.name ?? authorityEntry.id)}</p>
            <p class="mt-1 text-sm text-ink-muted font-mono">@{String(authorityEntry.data.authorityIdentifier ?? authorityEntry.id)}</p>
          </a>
        </section>
      )}

      {/* Source / target scope */}
      {isSystemCode && (
        <section>
          <p class="eyebrow mb-3">Conversion scope</p>
          <dl class="border-t border-rule">
            <div class="grid grid-cols-[140px_1fr] gap-4 py-3 border-b border-rule">
              <dt class="eyebrow pt-1">Source</dt>
              <dd class="space-y-2">
                {sourceSpellingEntry ? (
                  <div>
                    <a href={`/register/spelling-system/i/${sourceSpellingEntry.id}`} class="font-mono text-blue dark:text-blue-bright hover:underline">
                      {sourceSpellingEntry.id}
                    </a>
                    <span class="ml-2 text-xs text-ink-subtle">spelling system</span>
                  </div>
                ) : (
                  <span class="font-mono text-ink">—</span>
                )}
                {sourceLanguage && (
                  <div>
                    <CodeChip kind="language" code={sourceLanguage} codeHref={`/register/iso639/${sourceLanguage}`} />
                  </div>
                )}
                {sourceScript && (
                  <div>
                    <CodeChip kind="script" code={sourceScript} codeHref={`/register/iso15924/${sourceScript}`} />
                  </div>
                )}
              </dd>
            </div>
            <div class="grid grid-cols-[140px_1fr] gap-4 py-3 border-b border-rule">
              <dt class="eyebrow pt-1">Target</dt>
              <dd class="space-y-2">
                {targetSpellingEntry ? (
                  <div>
                    <a href={`/register/spelling-system/i/${targetSpellingEntry.id}`} class="font-mono text-blue dark:text-blue-bright hover:underline">
                      {targetSpellingEntry.id}
                    </a>
                    <span class="ml-2 text-xs text-ink-subtle">spelling system</span>
                  </div>
                ) : targetScript ? (
                  <div>
                    <CodeChip kind="script" code={targetScript} codeHref={`/register/iso15924/${targetScript}`} />
                  </div>
                ) : (
                  <span class="font-mono text-ink">—</span>
                )}
                {targetLanguage && (
                  <div>
                    <CodeChip kind="language" code={targetLanguage} codeHref={`/register/iso639/${targetLanguage}`} />
                  </div>
                )}
                {targetScript && targetSpellingEntry && (
                  <div>
                    <CodeChip kind="script" code={targetScript} codeHref={`/register/iso15924/${targetScript}`} />
                  </div>
                )}
              </dd>
            </div>
          </dl>
        </section>
      )}

      {/* Relations */}
      {isSystemCode && relations.length > 0 && (
        <section>
          <p class="eyebrow mb-3">Relations</p>
          <ul class="border-t border-rule">
            {relations.map((r) => (
              <li class="grid grid-cols-[140px_1fr] gap-4 py-3 border-b border-rule items-baseline">
                <span class="eyebrow pt-0.5">{r.type}</span>
                <a href={`/register/system-code/i/${r.targetSystem}`} class="font-mono text-sm text-blue dark:text-blue-bright hover:underline break-all">
                  {r.targetName}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {/* Specification URLs */}
      {isSystemCode && specificationUrls.length > 0 && (
        <section>
          <p class="eyebrow mb-3">Specification</p>
          <ul class="space-y-2">
            {specificationUrls.map((u) => (
              <li>
                <a href={u} target="_blank" rel="noopener" class="text-blue dark:text-blue-bright underline break-all font-mono text-sm">
                  {u}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {/* References (defining + supporting) */}
      {isSystemCode && references.length > 0 && (
        <section>
          <p class="eyebrow mb-3">References</p>
          <p class="text-sm text-ink-subtle max-w-2xl mb-4 leading-relaxed">
            The first entry is the defining citation for this system. Subsequent entries are supporting material.
          </p>
          <ol class="border-t border-rule">
            {references.map((r, i) => {
              const isUnresolved = /^\[unresolved citation:/.test(r.title);
              const isDefining = i === 0;
              return (
                <li class="grid grid-cols-[2rem_1fr] gap-x-3 py-4 border-b border-rule items-baseline">
                  <span class="font-mono text-xs text-ink-subtle tabular-nums pt-0.5">
                    {isDefining ? '★' : String(i + 1).padStart(2, '0')}
                  </span>
                  <span class="space-y-2">
                    <span class="block">
                      <span class:list={[
                        'block font-display text-base md:text-lg font-semibold tracking-[-0.012em] leading-snug',
                        isUnresolved ? 'text-ink-subtle italic' : 'text-ink',
                      ]}>
                        {r.label}
                      </span>
                      <span class="block text-sm text-ink-muted leading-relaxed mt-1">
                        {r.title}
                      </span>
                    </span>
                    {(r.publisher || r.date) && (
                      <span class="block text-sm text-ink-muted">
                        {r.publisher && <span>{r.publisher}</span>}
                        {r.publisher && r.date && <span class="mx-1.5 text-ink-subtle">·</span>}
                        {r.date && <span>{r.date}</span>}
                      </span>
                    )}
                    {r.url && (
                      <a
                        href={r.url}
                        target="_blank"
                        rel="noopener"
                        class="block text-blue dark:text-blue-bright underline break-all font-mono text-sm hover:text-gold-deep dark:hover:text-gold-bright transition-colors"
                      >
                        {r.url}
                      </a>
                    )}
                    <span class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-ink-subtle">
                      <span class="font-mono">id: {r.id}</span>
                      {isDefining && <span class="badge badge-accepted">defining</span>}
                    </span>
                  </span>
                </li>
              );
            })}
          </ol>
        </section>
      )}

      {/* Editorial notes */}
      {isSystemCode && notes.length > 0 && (
        <section>
          <p class="eyebrow mb-3">Notes</p>
          <ul class="border-l-2 border-blue/40 dark:border-blue-bright/40 pl-4 space-y-2">
            {notes.map((n) => (
              <li class="text-sm text-ink-muted leading-relaxed">{n}</li>
            ))}
          </ul>
        </section>
      )}

      {/* Provenance */}
      {isSystemCode && provenance.length > 0 && (
        <section>
          <p class="eyebrow mb-3">Provenance</p>
          <ul class="space-y-1">
            {provenance.map((p_item) => (
              <li class="text-sm text-ink-subtle italic">{p_item}</li>
            ))}
          </ul>
        </section>
      )}

      {/* Examples */}
      {isSystemCode && examples.length > 0 && (
        <section>
          <p class="eyebrow mb-3">Examples</p>
          <ul class="border-t border-rule">
            {examples.map((ex) => (
              <li class="grid grid-cols-[1fr_auto_1fr] gap-x-3 gap-y-1 py-3 border-b border-rule items-baseline">
                <span class="font-mono text-base text-ink break-all">{ex.input}</span>
                <span aria-hidden="true" class="text-ink-subtle">→</span>
                <span class="font-mono text-base text-blue dark:text-blue-bright break-all">{ex.output}</span>
                {ex.remarks && (
                  <span class="col-span-3 text-sm text-ink-subtle italic">{ex.remarks}</span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )}

      {/* Spelling-system: source-of / target-of lists */}
      {isSpellingSystem && (sourceOfSystems.length > 0 || targetOfSystems.length > 0) && (
        <section>
          <p class="eyebrow mb-3">Systems using this spelling</p>
          {sourceOfSystems.length > 0 && (
            <div class="mb-6">
              <p class="text-sm font-semibold text-ink mb-2">As source ({sourceOfSystems.length})</p>
              <ul class="border-t border-rule">
                {sourceOfSystems.map((s) => (
                  <li class="border-b border-rule">
                    <a href={`/register/system-code/i/${s.id}`} class="flex items-baseline justify-between gap-3 py-2 group">
                      <span class="font-mono text-sm text-ink group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors truncate">{String(s.data.code ?? s.id)}</span>
                      <span class="text-xs text-ink-subtle shrink-0">{String(s.data.name ?? '')}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {targetOfSystems.length > 0 && (
            <div>
              <p class="text-sm font-semibold text-ink mb-2">As target ({targetOfSystems.length})</p>
              <ul class="border-t border-rule">
                {targetOfSystems.map((s) => (
                  <li class="border-b border-rule">
                    <a href={`/register/system-code/i/${s.id}`} class="flex items-baseline justify-between gap-3 py-2 group">
                      <span class="font-mono text-sm text-ink group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors truncate">{String(s.data.code ?? s.id)}</span>
                      <span class="text-xs text-ink-subtle shrink-0">{String(s.data.name ?? '')}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </section>
      )}

      {/* Full record table (always) */}
      <section>
        <p class="eyebrow mb-3">Full record</p>
        <dl class="border-t border-rule">
          {fields.map((field) => {
            const key = field.key as string;
            const isRemarks = key === 'remarks';
            const isAbstract = key === 'abstract';
            const isDescription = key === 'description';
            const isUri = key === 'uri';
            const isExamples = key === 'examples';
            const isSpecification = key === 'specification';
            const isReferences = key === 'references';
            // Skip fields already rendered in curated sections above
            if (isSystemCode && (isAbstract || isDescription || isUri)) return null;
            if (isSystemCode && isExamples && examples.length > 0) return null;
            if (isSystemCode && isSpecification && specificationUrls.length > 0) return null;
            if (isSystemCode && isReferences && references.length > 0) return null;
            return (
              <div class="grid grid-cols-[160px_1fr] gap-4 py-3 border-b border-rule">
                <dt class="text-xs font-medium text-ink-muted pt-1">{fieldLabel(key)}</dt>
                <dd class:list={[
                  'text-sm break-all',
                  isRemarks ? 'font-sans text-ink-muted leading-relaxed' : 'font-mono',
                ]}>
                  {fieldValue(key)}
                </dd>
              </div>
            );
          })}
        </dl>
      </section>
    </div>

    {/* ── Side column ─────────────────────────────────────────── */}
    <aside class="space-y-8">
      <section>
        <p class="eyebrow mb-3">Download</p>
        <ul class="text-sm space-y-1.5">
          <li><a href={`/register/${itemClass}/i/${uuid}.jsonld`} class="hover:text-gold-deep dark:hover:text-gold-bright">JSON-LD</a></li>
          <li><a href={`/register/${itemClass}/i/${uuid}.ttl`} class="hover:text-gold-deep dark:hover:text-gold-bright">Turtle (TTL)</a></li>
          <li><a href={`/register/${itemClass}/i/${uuid}.rdf`} class="hover:text-gold-deep dark:hover:text-gold-bright">RDF/XML</a></li>
        </ul>
      </section>

      <section>
        <p class="eyebrow mb-3">Reference</p>
        <ul class="text-sm space-y-1.5">
          <li><a href="/specs/ag-tor" class="hover:text-gold-deep dark:hover:text-gold-bright">Annex A ToR</a></li>
          <li><a href={externalLinks.iso24229Standard} class="hover:text-gold-deep dark:hover:text-gold-bright">ISO 24229 standard</a></li>
          <li><a href={externalLinks.iso639Standard} class="hover:text-gold-deep dark:hover:text-gold-bright">ISO 639 (language)</a></li>
          <li><a href={externalLinks.iso15924Standard} class="hover:text-gold-deep dark:hover:text-gold-bright">ISO 15924 (script)</a></li>
        </ul>
      </section>

      <section>
        <p class="eyebrow mb-3">Source data</p>
        <ul class="text-sm space-y-1.5">
          <li>
            <a
              href={`${repoUrls.register}/blob/main/${itemClass}/${uuid}.yaml`}
              target="_blank"
              rel="noopener"
              class="hover:text-gold-deep dark:hover:text-gold-bright inline-flex items-center gap-1"
            >
              YAML on GitHub
              <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true" class="opacity-70"><path d="M3 1h6v6M9 1L3 7M1 3v6h6" stroke="currentColor" stroke-width="1.4" fill="none"/></svg>
            </a>
          </li>
        </ul>
      </section>

      <section>
        <p class="eyebrow mb-3">Suggest a change</p>
        <a
          href={`${repoUrls.register}/issues/new?labels=amendment&title=${encodeURIComponent(`Amend ${uuid}`)}`}
          target="_blank"
          rel="noopener"
          class="text-sm hover:text-gold-deep dark:hover:text-gold-bright"
        >
          Open an issue →
        </a>
      </section>
    </aside>
  </div>
</Layout>
