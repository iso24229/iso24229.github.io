---
import Layout from '../../layouts/Layout.astro';
import RegistrationBadge from '../../components/RegistrationBadge.astro';
import { getCollection } from 'astro:content';
import { itemClassSlugs } from '../../domain/registry/ItemClassRegistry';
import { schemaWithRichData } from '../../content.config';
import {
  REGISTRATION_STATUS_ORDER,
  isRegistrationStatus,
  type RegistrationStatus,
} from '../../domain/registration/RegistrationStatus';

interface EntryLike { id: string; data: Record<string, unknown>; }

const perClass = await Promise.all(
  itemClassSlugs.map(async (slug) => {
    const collection = await getCollection(slug);
    const entries: EntryLike[] = collection.map((c) => ({
      id: c.id,
      data: c.data as Record<string, unknown>,
    }));
    const counts = new Map<RegistrationStatus, number>();
    for (const e of entries) {
      const s = e.data.registrationStatus;
      if (isRegistrationStatus(s)) counts.set(s, (counts.get(s) ?? 0) + 1);
    }
    return {
      slug,
      title: schemaWithRichData[slug].title,
      description: schemaWithRichData[slug].description,
      count: entries.length,
      counts,
    };
  }),
);

const total = perClass.reduce((sum, c) => sum + c.count, 0);
const authorities = perClass.find((c) => c.slug === 'authority')?.count ?? 0;
const systems = perClass.find((c) => c.slug === 'system-code')?.count ?? 0;

const totalCounts = new Map<RegistrationStatus, number>();
for (const c of perClass) {
  for (const [s, n] of c.counts) {
    totalCounts.set(s, (totalCounts.get(s) ?? 0) + n);
  }
}
const statusBreakdown = REGISTRATION_STATUS_ORDER
  .map((s) => ({ status: s, count: totalCounts.get(s) ?? 0 }))
  .filter((x) => x.count > 0);
---

<Layout title="Content">
  <section class="mb-12">
    <p class="eyebrow mb-4">Content</p>
    <h1 class="mb-6">Browse the register.</h1>
    <p class="text-lg text-ink-muted max-w-2xl leading-relaxed mb-8">
      The register contains every written language conversion system, authority, and spelling system that has been assigned an ISO 24229 code.
    </p>
    <div class="flex flex-wrap gap-x-8 gap-y-2 text-sm">
      <span class="text-ink-muted"><span class="font-mono text-ink font-semibold">{total}</span> total entries</span>
      <span class="text-ink-muted"><span class="font-mono text-ink font-semibold">{systems}</span> conversion systems</span>
      <span class="text-ink-muted"><span class="font-mono text-ink font-semibold">{authorities}</span> authorities</span>
    </div>
  </section>

  {statusBreakdown.length > 0 && (
    <section class="mb-12">
      <p class="eyebrow mb-4">Registration status</p>
      <p class="text-sm text-ink-muted max-w-2xl mb-5 leading-relaxed">
        Every entry in the register carries an ISO 19135 registration lifecycle state. Most content today is <strong>proposed</strong> — awaiting Advisory Group review.
      </p>
      <ul class="flex flex-wrap gap-x-6 gap-y-3">
        {statusBreakdown.map(({ status, count }) => (
          <li class="flex items-center gap-3">
            <RegistrationBadge status={status} />
            <span class="font-mono text-sm text-ink">{count}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section>
    <p class="eyebrow mb-4">Item classes</p>
    <ul class="border-t border-rule">
      {perClass.map((c) => (
        <li class="border-b border-rule">
          <a href={`/register/${c.slug}/p/1`} class="flex items-baseline justify-between gap-4 py-4 group">
            <div class="flex-1 min-w-0">
              <h2 class="text-lg font-semibold tracking-tight group-hover:text-gold-deep dark:group-hover:text-gold-bright transition-colors">{c.title}</h2>
              {c.description && <p class="text-sm text-ink-muted mt-0.5">{c.description}</p>}
              {c.counts.size > 0 && (
                <ul class="mt-2 flex flex-wrap gap-x-3 gap-y-1">
                  {[...c.counts.entries()].map(([status, n]) => (
                    <li class="flex items-center gap-1.5 text-xs">
                      <RegistrationBadge status={status} />
                      <span class="font-mono text-ink-subtle">{n}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
            <span class="shrink-0 font-mono text-sm text-ink-subtle">{c.count}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="rule-section">
    <p class="eyebrow mb-3">Authorities</p>
    <p class="text-sm">
      <a href="/register/authority" class="text-ink-muted hover:text-gold-deep dark:hover:text-gold-bright">Browse the authority directory →</a>
    </p>
  </section>
</Layout>
