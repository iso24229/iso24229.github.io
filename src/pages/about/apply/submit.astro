---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Build dropdown options for approved authorities + spelling systems
const authorities = (await getCollection('authority'))
  .map((c) => ({
    id: c.id,
    identifier: String((c.data as Record<string, unknown>).authorityIdentifier ?? c.id),
    name: String((c.data as Record<string, unknown>).name ?? c.id),
  }))
  .sort((a, b) => a.identifier.localeCompare(b.identifier));
---

<Layout title="Submit a proposal">
  <p class="text-sm text-ink-subtle mb-2">
    <a href="/about/apply" class="hover:text-gold-deep dark:hover:text-gold-bright">← Apply</a>
  </p>
  <p class="eyebrow mb-3">Interactive submission form</p>
  <h1 class="text-3xl md:text-4xl font-display font-bold tracking-[-0.035em] mb-3">Submit a proposal.</h1>
  <p class="text-base md:text-lg text-ink-muted max-w-2xl leading-relaxed mb-12">
    Fill in each field. The form validates as you type, generates a live preview of the proposed code, and produces ready-to-paste Markdown for a GitHub issue — with a SHA-256 integrity checksum the Registration Authority can verify.
  </p>

  <div class="lg:grid lg:grid-cols-[1fr_320px] lg:gap-12">
    <form id="proposal-form" class="space-y-12">

      {/* ── Submitter ───────────────────────────────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Submitter</legend>
        <div>
          <label class="block eyebrow mb-1.5" for="submitter-name">Your name *</label>
          <input id="submitter-name" name="submitter-name" type="text" required class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright" />
        </div>
        <div>
          <label class="block eyebrow mb-1.5" for="submitter-org">Organization (optional)</label>
          <input id="submitter-org" name="submitter-org" type="text" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright" />
        </div>
        <div>
          <label class="block eyebrow mb-1.5" for="submitter-role">Your relationship to the authority *</label>
          <select id="submitter-role" name="submitter-role" required class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright">
            <option value="">Select…</option>
            <option value="I am the authority, or an authorized representative of the authority">I am the authority, or an authorized representative</option>
            <option value="I am an interested third party proposing for an approved authority">Interested third party proposing for an approved authority</option>
            <option value="I am proposing for the Varia authority (Var)">Proposing for the Varia authority (Var)</option>
            <option value="I am proposing a NEW authority alongside this system">Proposing a NEW authority alongside this system</option>
          </select>
        </div>
      </fieldset>

      {/* ── Authority ──────────────────────────────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Authority</legend>
        <p class="text-sm text-ink-muted">Pick the authority this system belongs to. If you're proposing for Varia or a new authority, that's a separate path.</p>
        <div id="authority-existing-block">
          <label class="block eyebrow mb-1.5" for="authority">Existing approved authority</label>
          <select id="authority" name="authority" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright">
            <option value="">— Select an existing authority —</option>
            <option value="Var">Var — Varia authority (no specific authority)</option>
            {authorities.map((a) => (
              <option value={a.identifier}>{a.identifier} — {a.name}</option>
            ))}
          </select>
        </div>
        <div id="authority-new-block" class="hidden space-y-3 p-4 border border-rule rounded-sm bg-paper-raised">
          <p class="eyebrow">New authority information</p>
          <div>
            <label class="block text-xs font-medium text-ink-muted mb-1" for="new-auth-name">Full authority name</label>
            <input id="new-auth-name" type="text" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink" />
          </div>
          <div>
            <label class="block text-xs font-medium text-ink-muted mb-1" for="new-auth-id">Proposed short identifier (3–16 chars)</label>
            <input id="new-auth-id" type="text" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink" />
          </div>
          <div>
            <label class="block text-xs font-medium text-ink-muted mb-1" for="new-auth-country">Country (optional, ISO 3166-1 alpha-2)</label>
            <input id="new-auth-country" type="text" maxlength="2" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink" />
          </div>
          <div>
            <label class="block text-xs font-medium text-ink-muted mb-1" for="new-auth-contact">Official contact email</label>
            <input id="new-auth-contact" type="email" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink" />
          </div>
          <div>
            <label class="block text-xs font-medium text-ink-muted mb-1" for="new-auth-justification">One-sentence justification</label>
            <input id="new-auth-justification" type="text" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink" />
          </div>
        </div>
        <p id="authorization-confirm" class="hidden text-xs text-ink-subtle italic">Confirm on submission that you are authorized to propose on behalf of this authority.</p>
      </fieldset>

      {/* ── System identification ─────────────────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">System identification</legend>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block eyebrow mb-1.5" for="source-language">Source language (ISO 639) *</label>
            <input id="source-language" type="text" required pattern="[a-z]{3}(-[a-z]{3})?" maxlength="7" placeholder="amh" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink font-mono focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright" />
            <p class="text-xs text-ink-subtle mt-1">3-letter code. <a href="/register/iso639/" class="underline">Look up</a>.</p>
          </div>
          <div>
            <label class="block eyebrow mb-1.5" for="source-script">Source script (ISO 15924) *</label>
            <input id="source-script" type="text" required pattern="[A-Z][a-z]{3}" maxlength="4" placeholder="Ethi" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink font-mono focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright" />
            <p class="text-xs text-ink-subtle mt-1">4-letter title-case. <a href="/register/iso15924/" class="underline">Look up</a>.</p>
          </div>
          <div>
            <label class="block eyebrow mb-1.5" for="source-country">Source country (optional)</label>
            <input id="source-country" type="text" pattern="[A-Z]{2}" maxlength="2" placeholder="ET" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink font-mono focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright" />
            <p class="text-xs text-ink-subtle mt-1">ISO 3166-1 alpha-2.</p>
          </div>
          <div>
            <label class="block eyebrow mb-1.5" for="target-script">Target script (ISO 15924) *</label>
            <input id="target-script" type="text" required pattern="[A-Z][a-z]{3}" maxlength="4" placeholder="Latn" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink font-mono focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright" />
            <p class="text-xs text-ink-subtle mt-1">Usually <span class="font-mono">Latn</span> for romanizations.</p>
          </div>
        </div>
        <div>
          <label class="block eyebrow mb-1.5" for="identifying-segment">Identifying segment *</label>
          <input id="identifying-segment" type="text" required placeholder="2011" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink font-mono focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright" />
          <p class="text-xs text-ink-subtle mt-1">Usually a year (e.g. <span class="font-mono">2011</span>) but may include version info (<span class="font-mono">9-1995</span>, <span class="font-mono">WG-1912</span>).</p>
        </div>
        <div>
          <label class="block eyebrow mb-1.5" for="system-name">System name (human-readable) *</label>
          <input id="system-name" type="text" required placeholder="ALA-LC Romanization Table -- Amharic (2011)" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright" />
        </div>
        <div>
          <label class="block eyebrow mb-1.5" for="abstract">Abstract *</label>
          <textarea id="abstract" required rows="2" placeholder="One or two sentences describing the conversion system." class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright"></textarea>
        </div>
      </fieldset>

      {/* ── Defining reference ─────────────────────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Defining reference</legend>
        <div>
          <label class="block eyebrow mb-1.5" for="ref-title">Title *</label>
          <input id="ref-title" type="text" required class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink" />
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block eyebrow mb-1.5" for="ref-publisher">Publisher *</label>
            <input id="ref-publisher" type="text" required class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink" />
          </div>
          <div>
            <label class="block eyebrow mb-1.5" for="ref-date">Date *</label>
            <input id="ref-date" type="text" required placeholder="1997" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink" />
          </div>
        </div>
        <div>
          <label class="block eyebrow mb-1.5" for="ref-url">URL (optional)</label>
          <input id="ref-url" type="url" placeholder="https://…" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink font-mono" />
        </div>
      </fieldset>

      {/* ── Demonstrative sources (3 required) ─────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Demonstrative usage — three independent sources</legend>
        <p class="text-sm text-ink-muted">Public sources demonstrating actual use. Must be independent of both the authority and the submitter. Library catalogues, gazetteers, academic publications, government style guides, software localisation projects.</p>
        {[1, 2, 3].map((n) => (
          <div class="space-y-2 p-4 border border-rule rounded-sm">
            <p class="eyebrow">Source {n} *</p>
            <input id={`demo-${n}-title`} type="text" required placeholder="Title" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink" />
            <input id={`demo-${n}-url`} type="text" placeholder="URL or citation" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink font-mono" />
            <input id={`demo-${n}-usage`} type="text" required placeholder="One sentence: how it uses the system" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink" />
          </div>
        ))}
      </fieldset>

      {/* ── Justification + examples ───────────────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Justification & examples</legend>
        <div>
          <label class="block eyebrow mb-1.5" for="justification">Why this system needs an ISO 24229 code *</label>
          <textarea id="justification" required rows="4" placeholder="3–5 sentences. What problem does assigning a code solve? Who benefits?" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink"></textarea>
        </div>
        <div>
          <label class="block eyebrow mb-1.5" for="examples">Example conversions *</label>
          <textarea id="examples" required rows="3" placeholder="One per line, format: input → output (optional remark)&#10;e.g.&#10;አማርኛ → amarəñya" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink font-mono"></textarea>
        </div>
        <div>
          <label class="block eyebrow mb-1.5" for="relations">Relations to other systems (optional)</label>
          <textarea id="relations" rows="2" placeholder="One per line, e.g. supersedes: alalc:amh-Ethi:Latn:1997" class="w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink font-mono"></textarea>
        </div>
      </fieldset>

      {/* ── Terms ─────────────────────────────────────────── */}
      <fieldset class="space-y-3">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Submission terms</legend>
        <label class="flex items-baseline gap-3 text-sm text-ink-muted leading-relaxed">
          <input type="checkbox" required class="mt-1" />
          <span>I confirm the information is accurate to the best of my knowledge.</span>
        </label>
        <label class="flex items-baseline gap-3 text-sm text-ink-muted leading-relaxed">
          <input type="checkbox" required class="mt-1" />
          <span>I understand the AG may reject this proposal, and that rejection does not result in a register entry.</span>
        </label>
        <label class="flex items-baseline gap-3 text-sm text-ink-muted leading-relaxed">
          <input type="checkbox" required class="mt-1" />
          <span>I understand this proposal is public, but the AG's deliberation (including voting) is private.</span>
        </label>
        <label class="flex items-baseline gap-3 text-sm text-ink-muted leading-relaxed">
          <input type="checkbox" required class="mt-1" />
          <span>I will enable GitHub notifications so I receive RA questions and the AG decision.</span>
        </label>
      </fieldset>
    </form>

    {/* ── Live preview / output ──────────────────────────── */}
    <aside class="lg:sticky lg:top-[calc(var(--header-height)+1.5rem)] lg:self-start space-y-6">
      <div class="border border-rule rounded-sm p-5 bg-paper-raised">
        <p class="eyebrow mb-3">Code preview</p>
        <p id="code-preview" class="font-mono text-sm break-all leading-relaxed text-ink-muted">—</p>
      </div>

      <div class="border border-rule rounded-sm p-5 bg-paper-raised">
        <p class="eyebrow mb-3">Validation</p>
        <ul id="validation-list" class="text-xs space-y-1 text-ink-subtle">
          <li>Fill in required fields to validate.</li>
        </ul>
      </div>

      <div class="border border-rule rounded-sm p-5 bg-paper-raised">
        <p class="eyebrow mb-3">Output</p>
        <p class="text-xs text-ink-subtle mb-3">Ready-to-paste Markdown for the GitHub issue, with SHA-256 checksum of the structured data.</p>
        <pre id="output-markdown" class="font-mono text-xs whitespace-pre-wrap break-words bg-paper p-3 border border-rule rounded-sm max-h-64 overflow-y-auto text-ink-muted">—</pre>
        <p class="text-xs text-ink-subtle mt-2">SHA-256: <code id="checksum" class="font-mono break-all">—</code></p>
        <div class="mt-4 space-y-2">
          <button type="button" id="copy-btn" class="w-full px-3 py-2 text-sm font-medium rounded-sm bg-ink text-paper hover:bg-ink-muted transition-colors">Copy Markdown</button>
          <a id="open-gh-btn" href="https://github.com/iso24229/proposals/issues/new" target="_blank" rel="noopener" class="block text-center px-3 py-2 text-sm font-medium rounded-sm border border-ink text-ink hover:bg-paper-raised transition-colors">Open GitHub issue</a>
        </div>
      </div>
    </aside>
  </div>
</Layout>

<script is:inline define:vars={{}}>
  (function () {
    function init() {
      const form = document.getElementById('proposal-form');
      if (!form) return;

      const roleSel = document.getElementById('submitter-role');
      const authSel = document.getElementById('authority');
      const authExisting = document.getElementById('authority-existing-block');
      const authNew = document.getElementById('authority-new-block');
      const authConfirm = document.getElementById('authorization-confirm');

      // Role select controls which authority section is shown
      function syncRoleUI() {
        const role = roleSel.value;
        const isNew = role.includes('NEW authority');
        const isVar = role.includes('Varia');
        authExisting?.classList.toggle('hidden', isNew);
        authNew?.classList.toggle('hidden', !isNew);
        if (authSel && isVar) authSel.value = 'Var';
        if (authConfirm) {
          authConfirm.classList.toggle('hidden', !role);
        }
        regenerate();
      }
      roleSel?.addEventListener('change', syncRoleUI);
      authSel?.addEventListener('change', regenerate);

      // All inputs trigger regeneration
      form.querySelectorAll('input, textarea, select').forEach((el) => {
        el.addEventListener('input', regenerate);
        el.addEventListener('change', regenerate);
      });

      // ── Helpers ─────────────────────────────────────────
      function val(id) {
        const el = document.getElementById(id);
        return el ? el.value.trim() : '';
      }

      function normalizeLang(s) {
        return String(s || '').trim().toLowerCase();
      }
      function normalizeScript(s) {
        const t = String(s || '').trim();
        if (!t) return '';
        return t.charAt(0).toUpperCase() + t.slice(1).toLowerCase();
      }

      function buildCode(data) {
        const parts = [
          data.authority,
          [data.sourceLanguage, data.sourceScript, data.sourceCountry].filter(Boolean).join('-'),
          data.targetScript,
          data.identifyingSegment,
        ].filter(Boolean);
        return parts.join(':');
      }

      function buildStructured(data) {
        // Canonical JSON serialization for SHA-256 (deterministic key order)
        return JSON.stringify({
          submitter: {
            name: data.submitterName,
            organization: data.submitterOrg,
            role: data.submitterRole,
          },
          authority: {
            identifier: data.authority,
            newAuthority: data.isNewAuthority ? {
              name: data.newAuthName,
              identifier: data.newAuthId,
              country: data.newAuthCountry,
              contact: data.newAuthContact,
              justification: data.newAuthJustification,
            } : null,
          },
          system: {
            code: data.code,
            name: data.systemName,
            abstract: data.abstract,
            sourceLanguage: data.sourceLanguage,
            sourceScript: data.sourceScript,
            sourceCountry: data.sourceCountry,
            targetScript: data.targetScript,
            identifyingSegment: data.identifyingSegment,
          },
          definingReference: {
            title: data.refTitle,
            publisher: data.refPublisher,
            date: data.refDate,
            url: data.refUrl,
          },
          demonstrativeSources: [
            { title: data.demo1Title, url: data.demo1Url, usage: data.demo1Usage },
            { title: data.demo2Title, url: data.demo2Url, usage: data.demo2Usage },
            { title: data.demo3Title, url: data.demo3Url, usage: data.demo3Usage },
          ],
          justification: data.justification,
          examples: data.examples,
          relations: data.relations,
        });
      }

      async function sha256Hex(s) {
        const buf = new TextEncoder().encode(s);
        const hash = await crypto.subtle.digest('SHA-256', buf);
        return Array.from(new Uint8Array(hash)).map((b) => b.toString(16).padStart(2, '0')).join('');
      }

      function genMarkdown(data, checksum) {
        const role = data.submitterRole || '';
        const isNew = role.includes('NEW authority');
        const lines = [];

        function section(label, value) {
          lines.push(`### ${label}`);
          lines.push('');
          lines.push(value || '_(not provided)_');
          lines.push('');
        }

        lines.push(`<!-- ISO 24229 system-code proposal generated by www.iso24229.org/about/apply/submit -->`);
        lines.push(`<!-- integrity-sha256: ${checksum} -->`);
        lines.push('');

        section('Your name', data.submitterName);
        section('Organization (optional)', data.submitterOrg);
        section('Your relationship to the proposed authority', role);

        if (isNew) {
          lines.push('### Authority identifier');
          lines.push('');
          lines.push('_(new authority)_');
          lines.push('');
          section('New authority information',
            `Name: ${data.newAuthName}\nIdentifier: ${data.newAuthId}\nCountry: ${data.newAuthCountry}\nContact email: ${data.newAuthContact}\nJustification: ${data.newAuthJustification}`);
        } else {
          section('Authority identifier', data.authority);
        }

        section('Authorization', 'I confirm I am authorized to submit on behalf of the chosen authority, OR I am proposing for Varia, OR I am proposing a new authority.');

        section('Source language (ISO 639 code)', data.sourceLanguage);
        section('Source script (ISO 15924 code)', data.sourceScript);
        section('Source country (optional, ISO 3166-1 alpha-2)', data.sourceCountry);
        section('Target script (ISO 15924 code)', data.targetScript);
        section('Identifying segment', data.identifyingSegment);
        section('System name (human-readable)', data.systemName);
        section('Abstract', data.abstract);

        section('Defining reference — title', data.refTitle);
        section('Defining reference — publisher', data.refPublisher);
        section('Defining reference — date', data.refDate);
        section('Defining reference — URL (optional)', data.refUrl);

        section('Demonstrative source 1', `Title: ${data.demo1Title}\nURL: ${data.demo1Url}\nUsage: ${data.demo1Usage}`);
        section('Demonstrative source 2', `Title: ${data.demo2Title}\nURL: ${data.demo2Url}\nUsage: ${data.demo2Usage}`);
        section('Demonstrative source 3', `Title: ${data.demo3Title}\nURL: ${data.demo3Url}\nUsage: ${data.demo3Usage}`);

        section('Justification', data.justification);
        section('Example conversions', data.examples);
        section('Relations to other systems (optional)', data.relations);

        section('Submission terms', [
          '- [x] I confirm the information is accurate to the best of my knowledge',
          '- [x] I understand the AG may reject this proposal, and that rejection does not result in a register entry',
          '- [x] I understand this proposal is public, but the AG\'s deliberation is private',
          '- [x] I will enable GitHub notifications',
        ].join('\n'));

        return lines.join('\n');
      }

      function validate(data) {
        const issues = [];
        const required = (label, v) => { if (!v) issues.push(`Missing: ${label}`); };
        required('submitter name', data.submitterName);
        required('role', data.submitterRole);
        if (!data.isNewAuthority) required('authority', data.authority);
        required('source language (3-letter ISO 639)', data.sourceLanguage);
        required('source script (4-letter ISO 15924)', data.sourceScript);
        required('target script (4-letter ISO 15924)', data.targetScript);
        required('identifying segment', data.identifyingSegment);
        required('system name', data.systemName);
        required('abstract', data.abstract);
        required('defining reference title', data.refTitle);
        required('defining reference publisher', data.refPublisher);
        required('defining reference date', data.refDate);
        required('demonstrative source 1', data.demo1Title);
        required('demonstrative source 2', data.demo2Title);
        required('demonstrative source 3', data.demo3Title);
        required('justification', data.justification);
        required('example conversions', data.examples);

        // Format checks
        if (data.sourceLanguage && !/^[a-z]{3}(-[a-z]{3})?$/.test(data.sourceLanguage)) {
          issues.push('Source language must be 3 lowercase letters (e.g. "amh")');
        }
        if (data.sourceScript && !/^[A-Z][a-z]{3}$/.test(data.sourceScript)) {
          issues.push('Source script must be 4 letters title-case (e.g. "Ethi")');
        }
        if (data.targetScript && !/^[A-Z][a-z]{3}$/.test(data.targetScript)) {
          issues.push('Target script must be 4 letters title-case (e.g. "Latn")');
        }
        if (data.sourceCountry && !/^[A-Z]{2}$/.test(data.sourceCountry)) {
          issues.push('Source country must be 2 uppercase letters (e.g. "ET")');
        }
        return issues;
      }

      // ── Regenerate (debounced) ─────────────────────────
      let scheduled = false;
      function regenerate() {
        if (scheduled) return;
        scheduled = true;
        setTimeout(() => {
          scheduled = false;
          actuallyRegenerate();
        }, 50);
      }

      async function actuallyRegenerate() {
        const role = val('submitter-role');
        const isNewAuthority = role.includes('NEW authority');

        const data = {
          submitterName: val('submitter-name'),
          submitterOrg: val('submitter-org'),
          submitterRole: role,
          isNewAuthority,
          authority: isNewAuthority ? (val('new-auth-id') || '(new)') : val('authority'),
          newAuthName: val('new-auth-name'),
          newAuthId: val('new-auth-id'),
          newAuthCountry: val('new-auth-country'),
          newAuthContact: val('new-auth-contact'),
          newAuthJustification: val('new-auth-justification'),
          sourceLanguage: normalizeLang(val('source-language')),
          sourceScript: normalizeScript(val('source-script')),
          sourceCountry: val('source-country').toUpperCase(),
          targetScript: normalizeScript(val('target-script')),
          identifyingSegment: val('identifying-segment'),
          systemName: val('system-name'),
          abstract: val('abstract'),
          refTitle: val('ref-title'),
          refPublisher: val('ref-publisher'),
          refDate: val('ref-date'),
          refUrl: val('ref-url'),
          demo1Title: val('demo-1-title'),
          demo1Url: val('demo-1-url'),
          demo1Usage: val('demo-1-usage'),
          demo2Title: val('demo-2-title'),
          demo2Url: val('demo-2-url'),
          demo2Usage: val('demo-2-usage'),
          demo3Title: val('demo-3-title'),
          demo3Url: val('demo-3-url'),
          demo3Usage: val('demo-3-usage'),
          justification: val('justification'),
          examples: val('examples'),
          relations: val('relations'),
        };
        data.code = buildCode(data);

        // Update code preview
        const codePreview = document.getElementById('code-preview');
        if (codePreview) {
          codePreview.textContent = data.code || '—';
          codePreview.classList.toggle('text-ink-muted', !data.code);
          codePreview.classList.toggle('text-ink', !!data.code);
        }

        // Validation
        const issues = validate(data);
        const list = document.getElementById('validation-list');
        if (list) {
          if (issues.length === 0) {
            list.innerHTML = '<li class="text-ink">✓ All required fields filled</li>';
          } else {
            list.innerHTML = issues.slice(0, 8).map((i) => `<li class="text-ink-muted">— ${escapeHtml(i)}</li>`).join('') + (issues.length > 8 ? `<li class="text-ink-subtle">+ ${issues.length - 8} more</li>` : '');
          }
        }

        // SHA-256 of canonical JSON
        let checksum = '';
        if (data.submitterName || data.systemName) {
          try {
            checksum = await sha256Hex(buildStructured(data));
          } catch (e) {
            // crypto.subtle requires HTTPS or localhost — fail gracefully
            checksum = '(unavailable over insecure connection)';
          }
        }

        // Markdown
        const md = genMarkdown(data, checksum);
        const mdEl = document.getElementById('output-markdown');
        if (mdEl) mdEl.textContent = data.submitterName || data.systemName ? md : '—';
        const ckEl = document.getElementById('checksum');
        if (ckEl) ckEl.textContent = checksum || '—';

        // Open-GitHub-issue link with pre-filled body
        const ghBtn = document.getElementById('open-gh-btn');
        if (ghBtn) {
          const title = data.systemName ? `[Proposal] ${data.systemName}` : '[Proposal]';
          const url = `https://github.com/iso24229/proposals/issues/new?title=${encodeURIComponent(title)}&body=${encodeURIComponent(md)}`;
          ghBtn.setAttribute('href', url);
        }

        // Copy button
        const copyBtn = document.getElementById('copy-btn');
        if (copyBtn) {
          copyBtn.onclick = async () => {
            try {
              await navigator.clipboard.writeText(md);
              copyBtn.textContent = 'Copied ✓';
              setTimeout(() => { copyBtn.textContent = 'Copy Markdown'; }, 2000);
            } catch (e) {
              copyBtn.textContent = 'Copy failed — select manually';
            }
          };
        }
      }

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      syncRoleUI();
    }

    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>
