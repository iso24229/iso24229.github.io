---
import Layout from '../../../layouts/Layout.astro';
import FormField from '../../../components/FormField.astro';
import { getCollection } from 'astro:content';
import codeNames from '../../../data/code-names.json';
import { countries } from '../../../data/countries';

const authorities = (await getCollection('authority'))
  .map((c) => ({
    id: c.id,
    identifier: String((c.data as Record<string, unknown>).authorityIdentifier ?? c.id),
    name: String((c.data as Record<string, unknown>).name ?? c.id),
  }))
  .sort((a, b) => a.identifier.localeCompare(b.identifier));

const scripts = Object.entries((codeNames as any).scripts ?? {}) as [string, { name: string; url: string }][];
const languages = Object.entries((codeNames as any).languages ?? {}) as [string, { name: string; part: string; url: string }][];
const systems = (await getCollection('system-code'))
  .map((c) => ({
    id: c.id,
    code: String((c.data as Record<string, unknown>).code ?? c.id),
    name: String((c.data as Record<string, unknown>).name ?? c.id),
  }))
  .sort((a, b) => a.code.localeCompare(b.code));

const relationTypes = ['supersedes', 'supersededBy', 'basedOn', 'basisFor', 'aliasOf', 'adoptedFrom', 'relatedTo'];

const FIELD = 'w-full px-3 py-2 border border-rule rounded-sm bg-paper text-ink focus:outline-none focus:border-gold-deep dark:focus:border-gold-bright';
---

<Layout title="Submit a proposal">
  <p class="text-sm text-ink-subtle mb-2">
    <a href="/about/apply" class="hover:text-gold-deep dark:hover:text-gold-bright">← Apply</a>
  </p>
  <p class="eyebrow mb-3">Interactive submission form</p>
  <h1 class="text-3xl md:text-4xl font-display font-bold tracking-[-0.035em] mb-3">Submit a proposal.</h1>
  <p class="text-base md:text-lg text-ink-muted max-w-2xl leading-relaxed mb-6">
    Fill in each field. The form validates as you type, generates a live preview of the proposed code, and produces ready-to-paste Markdown for a GitHub issue — with a SHA-256 integrity checksum the Registration Authority can verify.
  </p>
  <div class="border-l-2 border-gold/60 dark:border-gold-bright/60 pl-4 py-2 mb-12 max-w-2xl">
    <p class="text-sm text-ink-muted leading-relaxed">
      <strong class="text-ink">GitHub account required.</strong> To submit this proposal you need a free GitHub account. When you click "Open GitHub issue" you'll be asked to sign in (or create an account). Your GitHub username becomes your verified identity for the proposal.
    </p>
  </div>

  {/* ── Data islands for combobox search ─────────────────────── */}
  <script type="application/json" id="lang-data" set:html={JSON.stringify(languages.map(([code, info]) => ({ value: code, label: info.name })))} />
  <script type="application/json" id="script-data" set:html={JSON.stringify(scripts.map(([code, info]) => ({ value: code, label: info.name })))} />
  <script type="application/json" id="system-data" set:html={JSON.stringify(systems.map((s) => ({ value: s.code, label: s.name })))} />
  <script type="application/json" id="country-data" set:html={JSON.stringify(countries.map((c) => ({ value: c.code, label: c.name })))} />

  <div class="lg:grid lg:grid-cols-[1fr_320px] lg:gap-12">
    <form id="proposal-form" class="space-y-12">

      {/* ── Submitter ───────────────────────────────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Submitter</legend>
        <FormField id="submitter-name" label="Your name" required>
          <input id="submitter-name" name="submitter-name" type="text" required class="form-input" />
        </FormField>
        <FormField id="submitter-org" label="Organization (optional)">
          <input id="submitter-org" name="submitter-org" type="text" class="form-input" />
        </FormField>
        <FormField id="submitter-role" label="Your relationship to the authority" required>
          <select id="submitter-role" name="submitter-role" required class="form-input">
            <option value="">Select…</option>
            <option value="I am the authority, or an authorized representative of the authority">I am the authority, or an authorized representative</option>
            <option value="I am an interested third party proposing for an approved authority">Interested third party proposing for an approved authority</option>
            <option value="I am proposing for the Varia authority (Var)">Proposing for the Varia authority (Var)</option>
            <option value="I am proposing a NEW authority alongside this system">Proposing a NEW authority alongside this system</option>
          </select>
        </FormField>
      </fieldset>

      {/* ── Authority ──────────────────────────────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Authority</legend>
        <div class="border-l-2 border-gold/40 dark:border-gold-bright/40 pl-4 py-2">
          <p class="text-sm text-ink-muted leading-relaxed">
            <strong class="text-ink">Not sure which authority?</strong> If the system is historic (the original authority no longer exists) or has no clear owner, choose <strong class="text-ink">Var — Varia authority</strong> below. The Advisory Group manages Varia systems directly — no authorization needed, faster to get approved. Only propose a new authority if you represent an active institution that will manage multiple systems.
          </p>
        </div>
        <div id="authority-existing-block">
          <FormField id="authority" label="Existing approved authority">
            <select id="authority" name="authority" class="form-input">
              <option value="">— Select an existing authority —</option>
              <option value="Var">Var — Varia authority (no specific authority)</option>
              {authorities.map((a) => (
                <option value={a.identifier}>{a.identifier} — {a.name}</option>
              ))}
            </select>
          </FormField>
        </div>
        <div id="authority-new-block" class="hidden space-y-3 p-4 border border-rule rounded-sm bg-paper-raised">
          <p class="eyebrow">New authority information</p>
          <FormField id="new-auth-name" label="Full authority name">
            <input id="new-auth-name" type="text" class="form-input" />
          </FormField>
          <FormField id="new-auth-id" label="Proposed short identifier (3–16 chars)">
            <input id="new-auth-id" type="text" class="form-input" />
          </FormField>
          <FormField id="new-auth-country" label="Country (optional, ISO 3166-1 alpha-2)">
            <input id="new-auth-country" type="text" maxlength="2" class="form-input form-input-mono" />
          </FormField>
          <FormField id="new-auth-contact" label="Official contact email">
            <input id="new-auth-contact" type="email" class="form-input" />
          </FormField>
          <FormField id="new-auth-justification" label="One-sentence justification">
            <input id="new-auth-justification" type="text" class="form-input" />
          </FormField>
        </div>
        <p id="authorization-confirm" class="hidden text-xs text-ink-subtle italic">Confirm on submission that you are authorized to propose on behalf of this authority.</p>
      </fieldset>

      {/* ── System identification ─────────────────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">System identification</legend>
        <div class="grid sm:grid-cols-2 gap-4">
          <FormField id="source-language" label="Source language (ISO 639)" required help="3-letter code. Type to search.">
            <input id="source-language" type="text" required pattern="[a-z]{3}(-[a-z]{3})?" maxlength="7" placeholder="amh" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" class="form-input form-input-mono" />
          </FormField>
          <FormField id="source-script" label="Source script (ISO 15924)" required help="4-letter title-case. Type to search.">
            <input id="source-script" type="text" required pattern="[A-Z][a-z]{3}" maxlength="4" placeholder="Ethi" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" class="form-input form-input-mono" />
          </FormField>
          <FormField id="source-country" label="Source country (optional)" help="ISO 3166-1 alpha-2. Type to search by country name or code.">
            <input id="source-country" type="text" placeholder="Ethiopia" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" class="form-input" />
          </FormField>
          <FormField id="target-script" label="Target script (ISO 15924)" required help={<>Usually <span class="font-mono">Latn</span> for romanizations.</>}>
            <input id="target-script" type="text" required pattern="[A-Z][a-z]{3}" maxlength="4" placeholder="Latn" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" class="form-input form-input-mono" />
          </FormField>
        </div>
        <FormField id="identifying-segment" label="Identifying segment" required help={<>Usually a year (e.g. <span class="font-mono">2011</span>) but may include version info (<span class="font-mono">9-1995</span>, <span class="font-mono">WG-1912</span>).</>}>
          <input id="identifying-segment" type="text" required placeholder="2011" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" class="form-input form-input-mono" />
        </FormField>
        <FormField id="system-name" label="System name (human-readable)" required>
          <input id="system-name" type="text" required placeholder="UNGEGN Romanization System -- Arabic (2017)" class="form-input" />
        </FormField>
        <FormField id="abstract" label="Abstract" required>
          <textarea id="abstract" required rows="2" placeholder="One or two sentences describing the conversion system." class="form-input"></textarea>
        </FormField>
      </fieldset>

      {/* ── Defining reference ─────────────────────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Defining reference</legend>
        <FormField id="ref-title" label="Title" required>
          <input id="ref-title" type="text" required class="form-input" />
        </FormField>
        <div class="grid sm:grid-cols-2 gap-4">
          <FormField id="ref-publisher" label="Publisher" required>
            <input id="ref-publisher" type="text" required class="form-input" />
          </FormField>
          <FormField id="ref-date" label="Date" required>
            <input id="ref-date" type="text" required placeholder="1997" class="form-input" />
          </FormField>
        </div>
        <FormField id="ref-url" label="URL (optional)">
          <input id="ref-url" type="url" placeholder="https://…" class="form-input form-input-mono" />
        </FormField>
      </fieldset>

      {/* ── Demonstrative sources (3 required) ─────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Demonstrative usage — three independent sources</legend>
        <p class="text-sm text-ink-muted">Public sources demonstrating actual use. Must be independent of both the authority and the submitter. Library catalogues, gazetteers, academic publications, government style guides, software localisation projects.</p>
        {[1, 2, 3].map((n) => (
          <div class="space-y-2 p-4 border border-rule rounded-sm">
            <p class="eyebrow">Source {n} *</p>
            <input id={`demo-${n}-title`} type="text" required placeholder="Title" class="form-input" />
            <input id={`demo-${n}-url`} type="text" placeholder="URL or citation" class="form-input form-input-mono" />
            <input id={`demo-${n}-usage`} type="text" required placeholder="One sentence: how it uses the system" class="form-input" />
          </div>
        ))}
      </fieldset>

      {/* ── Justification + examples ───────────────────────── */}
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Justification & examples</legend>
        <FormField id="justification" label="Why this system needs an ISO 24229 code" required>
          <textarea id="justification" required rows="4" placeholder="3–5 sentences. What problem does assigning a code solve? Who benefits?" class="form-input"></textarea>
        </FormField>
        <div>
          <label class="block eyebrow mb-2">Example conversions * (at least one)</label>
          <div id="examples-container" class="space-y-2"></div>
          <button type="button" id="add-example-btn" class="mt-2 text-sm text-blue dark:text-blue-bright hover:text-gold-deep dark:hover:text-gold-bright underline">
            + Add example
          </button>
        </div>
        <div>
          <label class="block eyebrow mb-2">Relations to other systems (optional)</label>
          <div id="relations-container" class="space-y-2"></div>
          <button type="button" id="add-relation-btn" class="mt-2 text-sm text-blue dark:text-blue-bright hover:text-gold-deep dark:hover:text-gold-bright underline">
            + Add relation
          </button>
        </div>
      </fieldset>

      {/* ── Terms ─────────────────────────────────────────── */}
      <fieldset class="space-y-3">
        <legend class="font-display text-lg font-semibold tracking-[-0.012em]">Submission terms</legend>
        <label class="flex items-baseline gap-3 text-sm text-ink-muted leading-relaxed">
          <input type="checkbox" required class="mt-1" />
          <span>I confirm the information is accurate to the best of my knowledge.</span>
        </label>
        <label class="flex items-baseline gap-3 text-sm text-ink-muted leading-relaxed">
          <input type="checkbox" required class="mt-1" />
          <span>I understand the AG may reject this proposal, and that rejection does not result in a register entry.</span>
        </label>
        <label class="flex items-baseline gap-3 text-sm text-ink-muted leading-relaxed">
          <input type="checkbox" required class="mt-1" />
          <span>I understand this proposal is public, but the AG's deliberation (including voting) is private.</span>
        </label>
        <label class="flex items-baseline gap-3 text-sm text-ink-muted leading-relaxed">
          <input type="checkbox" required class="mt-1" />
          <span>I will enable GitHub notifications so I receive RA questions and the AG decision.</span>
        </label>
      </fieldset>
    </form>

    {/* ── Live preview / output ──────────────────────────── */}
    <aside class="lg:sticky lg:top-[calc(var(--header-height)+1.5rem)] lg:self-start space-y-6">
      <div class="border border-rule rounded-sm p-5 bg-paper-raised">
        <p class="eyebrow mb-3">Code preview</p>
        <p id="code-preview" class="font-mono text-sm break-all leading-relaxed text-ink-muted">—</p>
      </div>

      <div class="border border-rule rounded-sm p-5 bg-paper-raised">
        <p class="eyebrow mb-3">Validation</p>
        <ul id="validation-list" class="text-xs space-y-1 text-ink-subtle">
          <li>Fill in required fields to validate.</li>
        </ul>
      </div>

      <div class="border border-rule rounded-sm p-5 bg-paper-raised">
        <p class="eyebrow mb-3">Output</p>
        <p class="text-xs text-ink-subtle mb-3">Ready-to-paste Markdown for the GitHub issue, with SHA-256 checksum of the structured data.</p>
        <pre id="output-markdown" class="font-mono text-xs whitespace-pre-wrap break-words bg-paper p-3 border border-rule rounded-sm max-h-64 overflow-y-auto text-ink-muted">—</pre>
        <p class="text-xs text-ink-subtle mt-2">SHA-256: <code id="checksum" class="font-mono break-all">—</code></p>
        <div class="mt-4 space-y-2">
          <button type="button" id="copy-btn" class="btn-primary w-full">Copy Markdown</button>
          <a id="open-gh-btn" href="https://github.com/iso24229/proposals/issues/new" target="_blank" rel="noopener" class="block text-center px-3 py-2 text-sm font-medium rounded-sm border border-ink text-ink hover:bg-paper-raised transition-colors">Open GitHub issue</a>
        </div>
      </div>
    </aside>
  </div>
</Layout>

{/* Combobox attachment — bundled module. Runs alongside the inline
    script below; they communicate through the DOM (input.value). */}
<script>
  import { attachCombobox } from '../../../scripts/combobox';

  function init() {
    const lang = JSON.parse(document.getElementById('lang-data')?.textContent || '[]');
    const script = JSON.parse(document.getElementById('script-data')?.textContent || '[]');
    const sys = JSON.parse(document.getElementById('system-data')?.textContent || '[]');
    const country = JSON.parse(document.getElementById('country-data')?.textContent || '[]');
    attachCombobox(document.getElementById('source-language') as HTMLInputElement | null, lang, 'Select a valid ISO 639 language code');
    attachCombobox(document.getElementById('source-script') as HTMLInputElement | null, script, 'Select a valid ISO 15924 script code');
    attachCombobox(document.getElementById('target-script') as HTMLInputElement | null, script, 'Select a valid ISO 15924 script code');
    attachCombobox(document.getElementById('source-country') as HTMLInputElement | null, country, 'Select a valid ISO 3166-1 alpha-2 country');
    (window as any).__sysOpts = sys;
  }
  init();
  document.addEventListener('astro:page-load', init);
</script>

<script is:inline>
  (function () {
    function init() {
      const form = document.getElementById('proposal-form');
      if (!form) return;

      const roleSel = document.getElementById('submitter-role');
      const authSel = document.getElementById('authority');
      const authExisting = document.getElementById('authority-existing-block');
      const authNew = document.getElementById('authority-new-block');
      const authConfirm = document.getElementById('authorization-confirm');

      function syncRoleUI() {
        const role = roleSel.value;
        const isNew = role.includes('NEW authority');
        const isVar = role.includes('Varia');
        authExisting?.classList.toggle('hidden', isNew);
        authNew?.classList.toggle('hidden', !isNew);
        if (authSel && isVar) authSel.value = 'Var';
        if (authConfirm) {
          authConfirm.classList.toggle('hidden', !role);
        }
        regenerate();
      }
      roleSel?.addEventListener('change', syncRoleUI);
      authSel?.addEventListener('change', regenerate);

      form.querySelectorAll('input, textarea, select').forEach((el) => {
        el.addEventListener('input', regenerate);
        el.addEventListener('change', regenerate);
      });

      function highlightRequired() {
        form.querySelectorAll('input[required], textarea[required], select[required]').forEach((el) => {
          const empty = !el.value.trim() || (el.tagName === 'SELECT' && el.value === '');
          el.classList.toggle('field-empty', empty);
        });
      }

      function val(id) { const el = document.getElementById(id); return el ? el.value.trim() : ''; }
      function normalizeLang(s) { return String(s || '').trim().toLowerCase(); }
      function normalizeScript(s) {
        const t = String(s || '').trim();
        if (!t) return '';
        return t.charAt(0).toUpperCase() + t.slice(1).toLowerCase();
      }

      function buildCode(data) {
        const parts = [
          data.authority,
          [data.sourceLanguage, data.sourceScript, data.sourceCountry].filter(Boolean).join('-'),
          data.targetScript,
          data.identifyingSegment,
        ].filter(Boolean);
        return parts.join(':');
      }

      function buildStructured(data) {
        return JSON.stringify({
          submitter: { name: data.submitterName, organization: data.submitterOrg, role: data.submitterRole },
          authority: {
            identifier: data.authority,
            newAuthority: data.isNewAuthority ? {
              name: data.newAuthName, identifier: data.newAuthId, country: data.newAuthCountry,
              contact: data.newAuthContact, justification: data.newAuthJustification,
            } : null,
          },
          system: {
            code: data.code, name: data.systemName, abstract: data.abstract,
            sourceLanguage: data.sourceLanguage, sourceScript: data.sourceScript,
            sourceCountry: data.sourceCountry, targetScript: data.targetScript,
            identifyingSegment: data.identifyingSegment,
          },
          definingReference: { title: data.refTitle, publisher: data.refPublisher, date: data.refDate, url: data.refUrl },
          demonstrativeSources: [
            { title: data.demo1Title, url: data.demo1Url, usage: data.demo1Usage },
            { title: data.demo2Title, url: data.demo2Url, usage: data.demo2Usage },
            { title: data.demo3Title, url: data.demo3Url, usage: data.demo3Usage },
          ],
          justification: data.justification,
          examples: data.examples,
          relations: data.relations,
        });
      }

      async function sha256Hex(s) {
        const buf = new TextEncoder().encode(s);
        const hash = await crypto.subtle.digest('SHA-256', buf);
        return Array.from(new Uint8Array(hash)).map((b) => b.toString(16).padStart(2, '0')).join('');
      }

      function genMarkdown(data, checksum) {
        const role = data.submitterRole || '';
        const isNew = role.includes('NEW authority');
        const lines = [];
        function section(label, value) { lines.push('### ' + label, '', value || '_(not provided)_', ''); }
        lines.push('<!-- ISO 24229 system-code proposal generated by www.iso24229.org/about/apply/submit -->');
        lines.push('<!-- integrity-sha256: ' + checksum + '>');
        lines.push('');
        section('Your name', data.submitterName);
        section('Organization (optional)', data.submitterOrg);
        section('Your relationship to the proposed authority', role);
        if (isNew) {
          lines.push('### Authority identifier', '', '_(new authority)_', '');
          section('New authority information',
            'Name: ' + data.newAuthName + '\nIdentifier: ' + data.newAuthId + '\nCountry: ' + data.newAuthCountry + '\nContact email: ' + data.newAuthContact + '\nJustification: ' + data.newAuthJustification);
        } else {
          section('Authority identifier', data.authority);
        }
        section('Authorization', 'I confirm I am authorized to submit on behalf of the chosen authority, OR I am proposing for Varia, OR I am proposing a new authority.');
        section('Source language (ISO 639 code)', data.sourceLanguage);
        section('Source script (ISO 15924 code)', data.sourceScript);
        section('Source country (optional, ISO 3166-1 alpha-2)', data.sourceCountry);
        section('Target script (ISO 15924 code)', data.targetScript);
        section('Identifying segment', data.identifyingSegment);
        section('System name (human-readable)', data.systemName);
        section('Abstract', data.abstract);
        section('Defining reference — title', data.refTitle);
        section('Defining reference — publisher', data.refPublisher);
        section('Defining reference — date', data.refDate);
        section('Defining reference — URL (optional)', data.refUrl);
        section('Demonstrative source 1', 'Title: ' + data.demo1Title + '\nURL: ' + data.demo1Url + '\nUsage: ' + data.demo1Usage);
        section('Demonstrative source 2', 'Title: ' + data.demo2Title + '\nURL: ' + data.demo2Url + '\nUsage: ' + data.demo2Usage);
        section('Demonstrative source 3', 'Title: ' + data.demo3Title + '\nURL: ' + data.demo3Url + '\nUsage: ' + data.demo3Usage);
        section('Justification', data.justification);
        if (data.examples && data.examples.length > 0) {
          section('Example conversions', data.examples.map((ex) => {
            const r = ex.remarks ? ' (' + ex.remarks + ')' : '';
            return ex.input + ' → ' + ex.output + r;
          }).join('\n'));
        }
        if (data.relations && data.relations.length > 0) {
          section('Relations to other systems (optional)', data.relations.map((r) => r.type + ': ' + r.target).join('\n'));
        }
        section('Submission terms', [
          '- [x] I confirm the information is accurate to the best of my knowledge',
          '- [x] I understand the AG may reject this proposal, and that rejection does not result in a register entry',
          '- [x] I understand this proposal is public, but the AG\'s deliberation is private',
          '- [x] I will enable GitHub notifications',
        ].join('\n'));
        return lines.join('\n');
      }

      const RELATION_TYPES = ['supersedes', 'supersededBy', 'basedOn', 'basisFor', 'aliasOf', 'adoptedFrom', 'relatedTo'];
      let exRowCounter = 0;
      function addExampleRow(input = '', output = '', remarks = '') {
        const container = document.getElementById('examples-container');
        if (!container) return;
        const id = ++exRowCounter;
        const row = document.createElement('div');
        row.className = 'example-row grid grid-cols-[1fr_auto_1fr] gap-2';
        row.dataset.exId = String(id);
        const inp = document.createElement('input');
        inp.type = 'text'; inp.placeholder = 'input'; inp.value = input;
        inp.className = 'form-input form-input-mono';
        const arr = document.createElement('span');
        arr.textContent = '→'; arr.className = 'self-center text-ink-subtle';
        const out = document.createElement('input');
        out.type = 'text'; out.placeholder = 'output'; out.value = output;
        out.className = 'form-input form-input-mono';
        const rem = document.createElement('input');
        rem.type = 'text'; rem.placeholder = 'remarks (optional)'; rem.value = remarks;
        rem.className = 'form-input';
        const remWrap = document.createElement('div');
        remWrap.className = 'col-span-3';
        remWrap.appendChild(rem);
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button'; removeBtn.textContent = '✕';
        removeBtn.className = 'col-span-3 justify-self-end text-sm text-ink-subtle hover:text-red-600';
        removeBtn.onclick = () => { row.remove(); regenerate(); };
        row.appendChild(inp); row.appendChild(arr); row.appendChild(out); row.appendChild(remWrap); row.appendChild(removeBtn);
        container.appendChild(row);
        [inp, out, rem].forEach((el) => el.addEventListener('input', regenerate));
      }
      function collectExamples() {
        return Array.from(document.querySelectorAll('#examples-container .example-row')).map((row) => {
          const inputs = row.querySelectorAll('input');
          return { input: inputs[0].value.trim(), output: inputs[1].value.trim(), remarks: inputs[2].value.trim() };
        }).filter((ex) => ex.input || ex.output);
      }

      let relRowCounter = 0;
      function addRelationRow(type = '', target = '') {
        const container = document.getElementById('relations-container');
        if (!container) return;
        const id = ++relRowCounter;
        const row = document.createElement('div');
        row.className = 'relation-row flex items-center gap-2';
        row.dataset.relId = String(id);
        const typeSel = document.createElement('select');
        typeSel.className = 'form-input shrink-0';
        typeSel.innerHTML = '<option value="">type…</option>' + RELATION_TYPES.map((t) => '<option value="' + t + '"' + (type === t ? ' selected' : '') + '>' + t + '</option>').join('');
        const targetWrap = document.createElement('div');
        targetWrap.className = 'flex-1';
        const targetInput = document.createElement('input');
        targetInput.type = 'text'; targetInput.placeholder = 'search target system…'; targetInput.value = target;
        targetInput.autocomplete = 'off'; targetInput.autocapitalize = 'off'; targetInput.spellcheck = false;
        targetInput.setAttribute('autocorrect', 'off');
        targetInput.className = 'form-input form-input-mono';
        targetWrap.appendChild(targetInput);
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button'; removeBtn.textContent = '✕';
        removeBtn.className = 'shrink-0 px-2 py-1 text-sm text-ink-subtle hover:text-red-600';
        removeBtn.onclick = () => { row.remove(); regenerate(); };
        row.appendChild(typeSel); row.appendChild(targetWrap); row.appendChild(removeBtn);
        container.appendChild(row);
        const sysOpts = (window.__sysOpts || []);
        const dd = document.createElement('div'); dd.className = 'cb-dropdown'; targetWrap.appendChild(dd);
        const err = document.createElement('div'); err.className = 'cb-error';
        err.textContent = 'Select a valid system code from the list';
        targetWrap.parentNode.insertBefore(err, targetWrap.nextSibling);
        let selVal = '', activeIdx = -1, selecting = false;
        function render(q) {
          q = (q || '').toLowerCase().trim();
          const m = q ? sysOpts.filter((o) => o.value.toLowerCase().includes(q) || o.label.toLowerCase().includes(q)).slice(0, 50) : sysOpts.slice(0, 50);
          activeIdx = -1;
          dd.innerHTML = m.length ? m.map((o, i) => '<div class="cb-option" data-value="' + o.value + '"><div class="cb-option-value">' + o.value + '</div><div class="cb-option-label">' + o.label + '</div></div>').join('') : '<div class="cb-empty">No matches</div>';
          dd.classList.add('visible');
        }
        function hide() { dd.classList.remove('visible'); activeIdx = -1; }
        function validate() {
          const v = targetInput.value.trim();
          if (!v || selVal === v) { err.classList.remove('visible'); targetInput.classList.remove('field-invalid'); return; }
          const match = sysOpts.find((o) => o.value.toLowerCase() === v.toLowerCase());
          if (match) { selVal = match.value; err.classList.remove('visible'); targetInput.classList.remove('field-invalid'); return; }
          err.classList.add('visible'); targetInput.classList.add('field-invalid');
        }
        function setActive(i) {
          dd.querySelectorAll('.cb-active').forEach((el) => el.classList.remove('cb-active'));
          const opts = dd.querySelectorAll('.cb-option');
          if (i >= 0 && i < opts.length) { opts[i].classList.add('cb-active'); opts[i].scrollIntoView({ block: 'nearest' }); activeIdx = i; }
        }
        targetInput.addEventListener('focus', () => render(targetInput.value));
        targetInput.addEventListener('input', () => { if (selecting) return; selVal = ''; render(targetInput.value); validate(); });
        targetInput.addEventListener('keydown', (e) => {
          const opts = dd.querySelectorAll('.cb-option');
          if (!dd.classList.contains('visible') || !opts.length) return;
          if (e.key === 'ArrowDown') { e.preventDefault(); setActive(Math.min(activeIdx + 1, opts.length - 1)); }
          else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(Math.max(activeIdx - 1, 0)); }
          else if (e.key === 'Enter' && activeIdx >= 0) { e.preventDefault(); opts[activeIdx].click(); }
          else if (e.key === 'Escape') hide();
        });
        dd.addEventListener('mousedown', (e) => e.preventDefault());
        dd.addEventListener('click', (e) => {
          const opt = e.target.closest('.cb-option');
          if (!opt) return;
          selecting = true;
          targetInput.value = opt.dataset.value; selVal = opt.dataset.value;
          hide(); validate();
          targetInput.dispatchEvent(new Event('input', { bubbles: true }));
          selecting = false;
        });
        targetInput.addEventListener('blur', () => { setTimeout(() => { hide(); validate(); }, 150); });
        typeSel.addEventListener('change', regenerate);
        targetInput.addEventListener('input', regenerate);
      }
      function collectRelations() {
        return Array.from(document.querySelectorAll('#relations-container .relation-row')).map((row) => {
          const type = row.querySelector('select')?.value?.trim();
          const target = row.querySelector('input')?.value?.trim();
          if (type && target) return { type, target };
          return null;
        }).filter(Boolean);
      }

      document.getElementById('add-example-btn')?.addEventListener('click', () => addExampleRow());
      document.getElementById('add-relation-btn')?.addEventListener('click', () => addRelationRow());
      addExampleRow();

      let scheduled = false;
      function regenerate() {
        if (scheduled) return;
        scheduled = true;
        setTimeout(() => { scheduled = false; actuallyRegenerate(); }, 50);
      }

      async function actuallyRegenerate() {
        const role = val('submitter-role');
        const isNewAuthority = role.includes('NEW authority');
        const data = {
          submitterName: val('submitter-name'), submitterOrg: val('submitter-org'), submitterRole: role,
          isNewAuthority,
          authority: isNewAuthority ? (val('new-auth-id') || '(new)') : val('authority'),
          newAuthName: val('new-auth-name'), newAuthId: val('new-auth-id'),
          newAuthCountry: val('new-auth-country'), newAuthContact: val('new-auth-contact'),
          newAuthJustification: val('new-auth-justification'),
          sourceLanguage: normalizeLang(val('source-language')),
          sourceScript: normalizeScript(val('source-script')),
          sourceCountry: val('source-country').toUpperCase(),
          targetScript: normalizeScript(val('target-script')),
          identifyingSegment: val('identifying-segment'),
          systemName: val('system-name'), abstract: val('abstract'),
          refTitle: val('ref-title'), refPublisher: val('ref-publisher'),
          refDate: val('ref-date'), refUrl: val('ref-url'),
          demo1Title: val('demo-1-title'), demo1Url: val('demo-1-url'), demo1Usage: val('demo-1-usage'),
          demo2Title: val('demo-2-title'), demo2Url: val('demo-2-url'), demo2Usage: val('demo-2-usage'),
          demo3Title: val('demo-3-title'), demo3Url: val('demo-3-url'), demo3Usage: val('demo-3-usage'),
          justification: val('justification'),
          examples: collectExamples(),
          relations: collectRelations(),
        };
        data.code = buildCode(data);

        const codePreview = document.getElementById('code-preview');
        if (codePreview) codePreview.textContent = data.code || '—';

        highlightRequired();

        const valList = document.getElementById('validation-list');
        if (valList) {
          const items = [];
          if (!data.submitterName) items.push('Submitter name required');
          if (!data.submitterRole) items.push('Submitter role required');
          if (isNewAuthority) {
            if (!data.newAuthName) items.push('New authority name required');
            if (!data.newAuthId) items.push('New authority short identifier required');
          } else if (!data.authority) {
            items.push('Authority required');
          }
          if (!data.sourceLanguage) items.push('Source language required');
          if (!data.sourceScript) items.push('Source script required');
          if (!data.targetScript) items.push('Target script required');
          if (!data.identifyingSegment) items.push('Identifying segment required');
          if (!data.systemName) items.push('System name required');
          if (!data.abstract) items.push('Abstract required');
          if (!data.refTitle) items.push('Reference title required');
          if (!data.refPublisher) items.push('Reference publisher required');
          if (!data.refDate) items.push('Reference date required');
          if (!data.demo1Title) items.push('Demonstrative source 1 title required');
          if (!data.demo2Title) items.push('Demonstrative source 2 title required');
          if (!data.demo3Title) items.push('Demonstrative source 3 title required');
          if (!data.justification) items.push('Justification required');
          if (data.examples.length === 0) items.push('At least one example conversion required');
          valList.innerHTML = items.length
            ? items.map((i) => '<li>' + i + '</li>').join('')
            : '<li>✓ All fields filled — ready to submit.</li>';
        }

        const structured = buildStructured(data);
        const checksum = await sha256Hex(structured);
        const md = genMarkdown(data, checksum);
        const out = document.getElementById('output-markdown');
        if (out) out.textContent = md;
        const sumEl = document.getElementById('checksum');
        if (sumEl) sumEl.textContent = checksum;

        const openBtn = document.getElementById('open-gh-btn');
        if (openBtn) {
          const title = data.code ? 'Proposal: ' + data.code : 'New ISO 24229 system-code proposal';
          openBtn.href = 'https://github.com/iso24229/proposals/issues/new?title=' + encodeURIComponent(title) + '&body=' + encodeURIComponent(md);
        }

        const copyBtn = document.getElementById('copy-btn');
        if (copyBtn) {
          copyBtn.onclick = () => {
            navigator.clipboard.writeText(md).then(() => {
              copyBtn.textContent = 'Copied!';
              setTimeout(() => { copyBtn.textContent = 'Copy Markdown'; }, 1500);
            });
          };
        }
      }

      syncRoleUI();
    }

    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>
